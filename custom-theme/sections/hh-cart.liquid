{%- comment -%}
  Humble Hearted — cart page (dark/gold). Real Shopify cart: line items, qty, remove, checkout.
  Used via templates/cart.json + layout hh-standalone.
{%- endcomment -%}
{%- style -%}
  .hhx{--hh-bg:{{ section.settings.color_bg | default: '#080808' }};--hh-text:{{ section.settings.color_text | default: '#f2ede1' }};--hh-accent:{{ section.settings.color_accent | default: '#C4A843' }};--hh-ann-bg:{{ section.settings.ann_bg | default: '#C4A843' }};--hh-ann-text:{{ section.settings.ann_text_color | default: '#080808' }};}
  .hhx *,.hhx *::before,.hhx *::after{margin:0;padding:0;box-sizing:border-box;}
  .hhx{background:var(--hh-bg);color:var(--hh-text);font-family:'Montserrat',sans-serif;overflow-x:hidden;min-height:100vh;display:flex;flex-direction:column;}
  .hhx a{color:inherit;text-decoration:none;}
  @keyframes hhx-marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
  .hhx-ann{background:var(--hh-ann-bg);overflow:hidden;height:36px;display:flex;align-items:center;}
  .hhx-ann div{display:flex;animation:hhx-marquee 36s linear infinite;white-space:nowrap;}
  .hhx-ann span{font-size:10px;font-weight:700;letter-spacing:0.2em;color:var(--hh-ann-text);padding:0 32px;text-transform:uppercase;}
  .hhx-nav{background:var(--hh-bg);border-bottom:1px solid #1a1510;position:sticky;top:0;z-index:200;}
  .hhx-hn{max-width:1440px;margin:0 auto;padding:0 48px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;height:80px;}
  .hhx-link{color:var(--hh-text);font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;}
  .hhx-l{display:flex;gap:24px;align-items:center;}
  .hhx-r{display:flex;gap:18px;align-items:center;}
  .hhx-logo{justify-self:center;line-height:0;}
  .hhx-logo img{height:62px;width:auto;display:block;}
  .hhx-logo span{font-family:'Playfair Display',serif;font-size:24px;letter-spacing:0.15em;color:#f2ede1;}
  .hhx-ic{display:flex;gap:14px;align-items:center;border-left:1px solid #1f1a14;padding-left:16px;margin-left:2px;}
  .hbg{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:8px;}
  .hbg span{display:block;width:22px;height:2px;background:#f2ede1;border-radius:1px;}
  .hhx-wrap{flex:1;max-width:1180px;margin:0 auto;width:100%;padding:48px 48px 80px;}
  .hhx-head{text-align:center;margin-bottom:40px;}
  .hhx-eyebrow{font-size:10px;letter-spacing:0.3em;color:var(--hh-accent);font-weight:700;text-transform:uppercase;margin-bottom:12px;}
  .hhx-h1{font-family:'Playfair Display',serif;font-size:44px;color:var(--hh-text);font-weight:400;}
  .hhx-grid{display:grid;grid-template-columns:1fr 360px;gap:48px;align-items:start;}
  .hhx-row{display:grid;grid-template-columns:96px 1fr auto;gap:20px;padding:24px 0;border-bottom:1px solid #1a1510;align-items:center;}
  .hhx-img{width:96px;height:96px;background:#0e0c0a;overflow:hidden;}
  .hhx-img img{width:100%;height:100%;object-fit:cover;display:block;}
  .hhx-mat{font-size:9px;color:#C4A843;letter-spacing:0.12em;font-weight:700;text-transform:uppercase;margin-bottom:5px;}
  .hhx-name{font-family:'Playfair Display',serif;font-size:17px;color:#f2ede1;margin-bottom:5px;}
  .hhx-var{font-size:11px;color:rgba(242,237,225,0.45);font-weight:300;margin-bottom:10px;}
  .hhx-qty{display:inline-flex;align-items:center;border:1px solid rgba(242,237,225,0.22);}
  .hhx-qty a{width:34px;height:34px;display:flex;align-items:center;justify-content:center;color:#f2ede1;font-size:16px;}
  .hhx-qty span{min-width:38px;height:34px;display:flex;align-items:center;justify-content:center;font-size:13px;border-left:1px solid rgba(242,237,225,0.18);border-right:1px solid rgba(242,237,225,0.18);}
  .hhx-remove{display:inline-block;margin-left:16px;font-size:10px;letter-spacing:0.1em;color:rgba(242,237,225,0.4);text-transform:uppercase;border-bottom:1px solid rgba(242,237,225,0.2);padding-bottom:1px;}
  .hhx-lineprice{text-align:right;font-size:15px;color:#f2ede1;font-weight:600;white-space:nowrap;}
  .hhx-sum{background:#0d0b08;border:1px solid #1a1510;padding:28px;position:sticky;top:100px;}
  .hhx-sum h3{font-family:'Playfair Display',serif;font-size:20px;color:#f2ede1;font-weight:400;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid #1a1510;}
  .hhx-sumrow{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px;font-size:13px;color:rgba(242,237,225,0.6);font-weight:300;}
  .hhx-total{display:flex;justify-content:space-between;align-items:baseline;margin:18px 0;padding-top:18px;border-top:1px solid #1a1510;}
  .hhx-total .l{font-size:12px;letter-spacing:0.14em;text-transform:uppercase;font-weight:700;color:#f2ede1;}
  .hhx-total .v{font-size:24px;color:#f2ede1;font-weight:600;font-family:'Playfair Display',serif;}
  .hhx-note{font-size:11px;color:rgba(242,237,225,0.35);font-weight:300;margin-bottom:18px;line-height:1.6;}
  .hhx-checkout{width:100%;padding:16px;background:{{ section.settings.btn_bg | default: '#C4A843' }};color:{{ section.settings.btn_color | default: '#080808' }};font-size:11px;letter-spacing:0.2em;font-weight:800;text-transform:uppercase;border:none;cursor:pointer;margin-bottom:10px;}
  .hhx-update{width:100%;padding:13px;background:transparent;border:1px solid rgba(242,237,225,0.25);color:#f2ede1;font-size:10px;letter-spacing:0.18em;font-weight:700;text-transform:uppercase;cursor:pointer;}
  .hhx-cont{display:block;text-align:center;margin-top:16px;font-size:11px;letter-spacing:0.14em;color:var(--hh-accent);text-transform:uppercase;font-weight:700;}
  .hhx-empty{text-align:center;padding:60px 20px;}
  .hhx-empty p{font-size:15px;color:rgba(242,237,225,0.5);font-weight:300;margin-bottom:28px;}
  .hhx-btn{display:inline-block;padding:15px 44px;background:#C4A843;color:#080808;font-size:11px;letter-spacing:0.2em;font-weight:800;text-transform:uppercase;}
  .hhx-ft{background:#080808;padding:48px 48px 28px;border-top:1px solid #1a1510;}
  .hhx-ft-grid{max-width:1440px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:36px;padding-bottom:32px;border-bottom:1px solid #1a1510;}
  .hhx-ft h5{font-size:10px;letter-spacing:0.16em;color:#f2ede1;text-transform:uppercase;font-weight:700;margin-bottom:14px;}
  .hhx-ft .col a{display:block;font-size:12px;color:rgba(242,237,225,0.4);font-weight:300;margin-bottom:9px;}
  .hhx-ft-logo{height:52px;margin-bottom:12px;display:block;}
  .hhx-ft-bot{max-width:1440px;margin:0 auto;display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;padding-top:22px;}
  .hhx-ft-bot p,.hhx-ft-bot span{font-size:10px;color:rgba(242,237,225,0.2);font-weight:300;}
  @media(max-width:768px){.hbg{display:flex!important;}.hhx-l,.hhx-r,.hhx-ic{display:none!important;}.hhx-hn{grid-template-columns:auto 1fr auto!important;padding:0 18px!important;height:60px!important;}.hhx-logo img{height:46px!important;}.hhx-wrap{padding:32px 18px 60px;}.hhx-h1{font-size:34px;}.hhx-grid{grid-template-columns:1fr;gap:28px;}.hhx-sum{position:static;}.hhx-row{grid-template-columns:72px 1fr;gap:14px;}.hhx-img{width:72px;height:72px;}.hhx-lineprice{grid-column:2;text-align:left;margin-top:8px;}.hhx-ft-grid{grid-template-columns:1fr 1fr;}}
{%- endstyle -%}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
{%- if settings.logo != blank -%}{%- assign logo_src = settings.logo | image_url: height: 124 -%}{%- else -%}{%- assign logo_src = 'hh-logo.png' | asset_url -%}{%- endif -%}

<div class="hhx">
  <div class="hhx-ann"><div><span>{{ section.settings.announcement_text }} &nbsp;&#10022;&nbsp; {{ section.settings.announcement_text }} &nbsp;&#10022;&nbsp;</span></div></div>
  <nav class="hhx-nav"><div class="hhx-hn">
    <button class="hbg" aria-label="Menu" onclick="document.getElementById('hhxMenu').style.cssText='opacity:1;pointer-events:auto'"><span></span><span></span><span></span></button>
    <div class="hhx-l">
      <a class="hhx-link" href="/collections/necklaces">Necklaces</a><a class="hhx-link" href="/collections/rings">Rings</a><a class="hhx-link" href="/collections/bracelets">Bracelets</a><a class="hhx-link" href="/collections/earrings">Earrings</a>
    </div>
    <a class="hhx-logo" href="/"><img src="{{ logo_src }}" alt="{{ shop.name }}" onerror="this.outerHTML='<span>HUMBLE HEARTED</span>'"></a>
    <div style="display:flex;gap:12px;align-items:center;justify-content:flex-end;">
      <div class="hhx-r"><a class="hhx-link" href="/collections">Collections</a><a class="hhx-link" style="color:#C4A843;font-weight:700;" href="/collections/all?sort_by=created-descending">New</a><a class="hhx-link" href="/collections/gifts">Gifts</a></div>
      <div class="hhx-ic">
        <a href="/search" aria-label="Search"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path></svg></a>
        <a href="/account" aria-label="Account"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></a>
        <a href="/cart" aria-label="Cart"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C4A843" stroke-width="1.5" stroke-linecap="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg></a>
      </div>
    </div>
  </div></nav>

  <div class="hhx-wrap">
    <div class="hhx-head">
      <p class="hhx-eyebrow">{{ section.settings.page_eyebrow | default: 'Your Bag' }}</p>
      <h1 class="hhx-h1">{{ section.settings.page_heading | default: 'Shopping Bag' }}</h1>
    </div>

    {%- if cart.item_count == 0 -%}
      <div class="hhx-empty">
        <p>{{ section.settings.empty_message | default: 'Your bag is empty.' }}</p>
        <a class="hhx-btn" href="/collections/all">Start Shopping</a>
      </div>
    {%- else -%}
      <form action="{{ routes.cart_url }}" method="post" id="cart" class="hhx-grid">
        <div>
          {%- for item in cart.items -%}
            <div class="hhx-row">
              <a href="{{ item.url }}" class="hhx-img">{%- if item.image -%}<img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}">{%- endif -%}</a>
              <div>
                <p class="hhx-mat">{{ item.product.type | default: '18k Gold Vermeil' }}</p>
                <a href="{{ item.url }}"><p class="hhx-name">{{ item.product.title }}</p></a>
                {%- unless item.variant.title contains 'Default' -%}<p class="hhx-var">{{ item.variant.title }}</p>{%- endunless -%}
                <div>
                  <span class="hhx-qty">
                    <a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}" aria-label="Decrease">&minus;</a>
                    <span>{{ item.quantity }}</span>
                    <a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}" aria-label="Increase">+</a>
                  </span>
                  <a class="hhx-remove" href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0">Remove</a>
                </div>
              </div>
              <div class="hhx-lineprice">{{ item.final_line_price | money }}</div>
            </div>
          {%- endfor -%}
        </div>

        <div class="hhx-sum">
          <h3>Order Summary</h3>
          <div class="hhx-sumrow"><span>Subtotal</span><span style="color:#f2ede1;font-weight:600;">{{ cart.total_price | money }}</span></div>
          <div class="hhx-sumrow"><span>Shipping</span><span>Calculated at checkout</span></div>
          <div class="hhx-total"><span class="l">Total</span><span class="v">{{ cart.total_price | money }}</span></div>
          <p class="hhx-note">{{ section.settings.promo_note | default: 'Taxes and shipping calculated at checkout. Free standard shipping on orders $75+.' }}</p>
          <button type="submit" name="checkout" class="hhx-checkout">Checkout</button>
          <button type="submit" name="update" class="hhx-update">Update Bag</button>
          <a class="hhx-cont" href="/collections/all">{{ section.settings.continue_text | default: 'Continue Shopping' }} &rarr;</a>
        </div>
      </form>
    {%- endif -%}
  </div>

  <footer class="hhx-ft">
    <div class="hhx-ft-grid">
      <div>{%- if settings.logo != blank -%}<img class="hhx-ft-logo" src="{{ settings.logo | image_url: height: 104 }}" alt="{{ shop.name }}">{%- else -%}<div class="hhx-ft-logo"><span style="font-family:'Playfair Display',serif;font-size:22px;letter-spacing:0.15em;color:#f2ede1;">HUMBLE HEARTED</span></div>{%- endif -%}<p style="font-size:11px;color:rgba(242,237,225,0.35);line-height:1.8;max-width:230px;font-weight:300;">Luxury for the real. Crafted for people with beautiful hearts.</p></div>
      <div class="col"><h5>Shop</h5><a href="/collections/necklaces">Necklaces</a><a href="/collections/rings">Rings</a><a href="/collections/bracelets">Bracelets</a><a href="/collections/earrings">Earrings</a></div>
      <div class="col"><h5>Help</h5><a href="#">FAQs</a><a href="#">Shipping</a><a href="#">Returns</a></div>
      <div class="col"><h5>About</h5><a href="#">Our Story</a><a href="#">Sustainability</a></div>
    </div>
    <div class="hhx-ft-bot"><p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All Rights Reserved.</p><span>Visa &middot; Mastercard &middot; Amex &middot; Shop Pay &middot; Apple Pay</span></div>
  </footer>
</div>

<div id="hhxMenu" style="position:fixed;inset:0;z-index:999;background:#080808;display:flex;flex-direction:column;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.35s ease;padding:40px 24px;">
  <button onclick="document.getElementById('hhxMenu').style.cssText='opacity:0;pointer-events:none'" style="position:absolute;top:20px;right:20px;background:none;border:none;cursor:pointer;color:#f2ede1;font-size:32px;">&times;</button>
  <a href="/collections/necklaces" style="font-family:'Playfair Display',serif;font-size:26px;color:#f2ede1;margin-bottom:16px;">Necklaces</a>
  <a href="/collections/rings" style="font-family:'Playfair Display',serif;font-size:26px;color:#f2ede1;margin-bottom:16px;">Rings</a>
  <a href="/collections/bracelets" style="font-family:'Playfair Display',serif;font-size:26px;color:#f2ede1;margin-bottom:16px;">Bracelets</a>
  <a href="/collections/earrings" style="font-family:'Playfair Display',serif;font-size:26px;color:#f2ede1;margin-bottom:16px;">Earrings</a>
  <a href="/collections" style="font-size:13px;letter-spacing:0.18em;color:#f2ede1;text-transform:uppercase;font-weight:700;margin-bottom:11px;">Collections</a>
  <a href="/collections/all?sort_by=created-descending" style="font-size:13px;letter-spacing:0.18em;color:#C4A843;text-transform:uppercase;font-weight:700;margin-bottom:11px;">New</a>
  <a href="/collections/gifts" style="font-size:13px;letter-spacing:0.18em;color:#f2ede1;text-transform:uppercase;font-weight:700;">Gifts</a>
</div>

{% schema %}
{
  "name": "HH Cart",
  "settings": [
    { "type": "header", "content": "Announcement Bar" },
    { "type": "text", "id": "announcement_text", "label": "Announcement text", "default": "Free Shipping On Orders $75+ ✦ Sign Up For 10% Off ✦ 60-Day Returns ✦ 2-Year Warranty" },
    { "type": "color", "id": "ann_bg", "label": "Announcement background color", "default": "#C4A843" },
    { "type": "color", "id": "ann_text_color", "label": "Announcement text color", "default": "#080808" },
    { "type": "header", "content": "Cart Page Text" },
    { "type": "text", "id": "page_eyebrow", "label": "Eyebrow text", "default": "Your Bag" },
    { "type": "text", "id": "page_heading", "label": "Page heading", "default": "Shopping Bag" },
    { "type": "text", "id": "empty_message", "label": "Empty cart message", "default": "Your bag is empty." },
    { "type": "text", "id": "continue_text", "label": "Continue shopping link text", "default": "Continue Shopping" },
    { "type": "text", "id": "promo_note", "label": "Promo / free shipping note", "default": "Taxes and shipping calculated at checkout. Free standard shipping on orders $75+." },
    { "type": "header", "content": "Checkout Button" },
    { "type": "color", "id": "btn_bg", "label": "Checkout button background", "default": "#C4A843" },
    { "type": "color", "id": "btn_color", "label": "Checkout button text color", "default": "#080808" },
    { "type": "header", "content": "Page Colors" },
    { "type": "color", "id": "color_bg", "label": "Page background", "default": "#080808" },
    { "type": "color", "id": "color_text", "label": "Text color", "default": "#f2ede1" },
    { "type": "color", "id": "color_accent", "label": "Accent / gold color", "default": "#C4A843" }
  ]
}
{% endschema %}
