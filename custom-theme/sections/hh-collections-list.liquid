{%- comment -%}
  Humble Hearted — Collections list page (dark/gold). Grid of all collections.
  Used via templates/list-collections.json + layout hh-standalone.
{%- endcomment -%}
{%- style -%}
  .hhl *,.hhl *::before,.hhl *::after{margin:0;padding:0;box-sizing:border-box;}
  .hhl{background:#080808;color:#f2ede1;font-family:'Montserrat',sans-serif;overflow-x:hidden;min-height:100vh;display:flex;flex-direction:column;}
  .hhl a{color:inherit;text-decoration:none;}
  @keyframes hhl-marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
  .hhl-ann{background:#C4A843;overflow:hidden;height:36px;display:flex;align-items:center;}
  .hhl-ann div{display:flex;animation:hhl-marquee 36s linear infinite;white-space:nowrap;}
  .hhl-ann span{font-size:10px;font-weight:700;letter-spacing:0.2em;color:#080808;padding:0 32px;text-transform:uppercase;}
  .hhl-nav{background:#080808;border-bottom:1px solid #1a1510;position:sticky;top:0;z-index:200;}
  .hhl-hn{max-width:1440px;margin:0 auto;padding:0 48px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;height:80px;}
  .hhl-link{color:#f2ede1;font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;}
  .hhl-l{display:flex;gap:24px;align-items:center;}
  .hhl-r{display:flex;gap:18px;align-items:center;}
  .hhl-logo{justify-self:center;line-height:0;}
  .hhl-logo img{height:62px;width:auto;display:block;}
  .hhl-logo span{font-family:'Playfair Display',serif;font-size:24px;letter-spacing:0.15em;color:#f2ede1;}
  .hhl-ic{display:flex;gap:14px;align-items:center;border-left:1px solid #1f1a14;padding-left:16px;margin-left:2px;}
  .hbg{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:8px;}
  .hbg span{display:block;width:22px;height:2px;background:#f2ede1;border-radius:1px;}
  .hhl-hero{height:240px;position:relative;overflow:hidden;background:repeating-linear-gradient(45deg,#100a14 0,#100a14 18px,#180f1e 18px,#180f1e 36px);}
  .hhl-hero-in{position:absolute;inset:0;background:rgba(8,8,8,0.5);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:24px;}
  .hhl-eyebrow{font-size:10px;letter-spacing:0.3em;color:#C4A843;font-weight:700;text-transform:uppercase;margin-bottom:12px;}
  .hhl-h1{font-family:'Playfair Display',serif;font-size:52px;color:#f2ede1;font-weight:400;margin-bottom:10px;}
  .hhl-sub{font-size:12px;color:rgba(242,237,225,0.45);font-weight:300;letter-spacing:0.08em;}
  .hhl-wrap{flex:1;max-width:1440px;margin:0 auto;width:100%;padding:48px 48px 80px;}
  .hhl-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
  .hhl-card{position:relative;aspect-ratio:3/4;overflow:hidden;display:block;background:#0e0c0a;}
  .hhl-card-bg{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform 0.5s ease;}
  .hhl-card:hover .hhl-card-bg{transform:scale(1.04);}
  .hhl-card-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(8,8,8,0.9) 0%,rgba(8,8,8,0.15) 55%,rgba(8,8,8,0.35) 100%);display:flex;flex-direction:column;justify-content:flex-end;padding:28px;}
  .hhl-count{font-size:9px;letter-spacing:0.2em;color:#C4A843;font-weight:700;text-transform:uppercase;margin-bottom:8px;}
  .hhl-title{font-family:'Playfair Display',serif;font-size:28px;color:#f2ede1;font-weight:400;line-height:1.1;margin-bottom:10px;}
  .hhl-shop{font-size:10px;letter-spacing:0.2em;color:#f2ede1;text-transform:uppercase;font-weight:700;border-bottom:1px solid rgba(242,237,225,0.5);padding-bottom:3px;display:inline-block;}
  .hhl-ft{background:#080808;padding:48px 48px 28px;border-top:1px solid #1a1510;}
  .hhl-ft-grid{max-width:1440px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:36px;padding-bottom:32px;border-bottom:1px solid #1a1510;}
  .hhl-ft h5{font-size:10px;letter-spacing:0.16em;color:#f2ede1;text-transform:uppercase;font-weight:700;margin-bottom:14px;}
  .hhl-ft .col a{display:block;font-size:12px;color:rgba(242,237,225,0.4);font-weight:300;margin-bottom:9px;}
  .hhl-ft-logo{height:52px;margin-bottom:12px;display:block;}
  .hhl-ft-bot{max-width:1440px;margin:0 auto;display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;padding-top:22px;}
  .hhl-ft-bot p,.hhl-ft-bot span{font-size:10px;color:rgba(242,237,225,0.2);font-weight:300;}
  @media(max-width:1024px){.hhl-grid{grid-template-columns:repeat(2,1fr);}.hhl-ft-grid{grid-template-columns:1fr 1fr;}}
  @media(max-width:768px){.hbg{display:flex!important;}.hhl-l,.hhl-r,.hhl-ic{display:none!important;}.hhl-hn{grid-template-columns:auto 1fr auto!important;padding:0 18px!important;height:60px!important;}.hhl-logo img{height:46px!important;}.hhl-h1{font-size:38px;}.hhl-wrap{padding:32px 18px 60px;}.hhl-grid{grid-template-columns:1fr 1fr;gap:12px;}.hhl-card-ov{padding:18px;}.hhl-title{font-size:22px;}}
{%- endstyle -%}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
{%- if settings.logo != blank -%}{%- assign logo_src = settings.logo | image_url: height: 124 -%}{%- else -%}{%- assign logo_src = 'hh-logo.png' | asset_url -%}{%- endif -%}
{%- assign bgs = 'repeating-linear-gradient(135deg,#130f0a 0,#130f0a 13px,#1c1610 13px,#1c1610 26px)|repeating-linear-gradient(45deg,#0a0d12 0,#0a0d12 13px,#0f121a 13px,#0f121a 26px)|repeating-linear-gradient(135deg,#110e07 0,#110e07 13px,#19140a 13px,#19140a 26px)|repeating-linear-gradient(45deg,#0f0a12 0,#0f0a12 13px,#160f1a 13px,#160f1a 26px)' | split: '|' -%}

<div class="hhl">
  <div class="hhl-ann"><div><span>{{ section.settings.announcement_text }} &nbsp;&#10022;&nbsp; {{ section.settings.announcement_text }} &nbsp;&#10022;&nbsp;</span></div></div>
  <nav class="hhl-nav"><div class="hhl-hn">
    <button class="hbg" aria-label="Menu" onclick="document.getElementById('hhlMenu').style.cssText='opacity:1;pointer-events:auto'"><span></span><span></span><span></span></button>
    <div class="hhl-l"><a class="hhl-link" href="/collections/necklaces">Necklaces</a><a class="hhl-link" href="/collections/rings">Rings</a><a class="hhl-link" href="/collections/bracelets">Bracelets</a><a class="hhl-link" href="/collections/earrings">Earrings</a></div>
    <a class="hhl-logo" href="/"><img src="{{ logo_src }}" alt="{{ shop.name }}" onerror="this.outerHTML='<span>HUMBLE HEARTED</span>'"></a>
    <div style="display:flex;gap:12px;align-items:center;justify-content:flex-end;">
      <div class="hhl-r"><a class="hhl-link" style="color:#C4A843;font-weight:700;" href="/collections">Collections</a><a class="hhl-link" href="/collections/all?sort_by=created-descending">New</a><a class="hhl-link" href="/collections/gifts">Gifts</a></div>
      <div class="hhl-ic">
        <a href="/search" aria-label="Search"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path></svg></a>
        <a href="/account" aria-label="Account"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></a>
        <a href="/cart" aria-label="Cart"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg></a>
      </div>
    </div>
  </div></nav>

  <section class="hhl-hero" style="{% if section.settings.hero_image != blank %}background-image:url('{{ section.settings.hero_image | image_url: width: 1600 }}');background-size:cover;background-position:center;{% endif %}"><div class="hhl-hero-in">
    <p class="hhl-eyebrow">{{ section.settings.hero_eyebrow | default: 'Explore' }}</p>
    <h1 class="hhl-h1">{{ section.settings.hero_heading | default: 'Collections' }}</h1>
    <p class="hhl-sub">{{ section.settings.hero_sub | default: 'Shop every Humble Hearted collection' }}</p>
  </div></section>

  <div class="hhl-wrap">
    <div class="hhl-grid">
      {%- assign idx = 0 -%}
      {%- for collection in collections -%}
        {%- unless collection.handle == 'frontpage' -%}
          {%- assign bi = idx | modulo: 4 -%}
          {%- assign idx = idx | plus: 1 -%}
          <a href="{{ collection.url }}" class="hhl-card">
            <div class="hhl-card-bg" style="{% if collection.image %}background-image:url('{{ collection.image | image_url: width: 700 }}');{% elsif collection.products.first.featured_image %}background-image:url('{{ collection.products.first.featured_image | image_url: width: 700 }}');{% else %}background:{{ bgs[bi] }};{% endif %}"></div>
            <div class="hhl-card-ov">
              <p class="hhl-count">{{ collection.products_count }} Piece{% if collection.products_count != 1 %}s{% endif %}</p>
              <p class="hhl-title">{{ collection.title }}</p>
              <span class="hhl-shop">Shop Now &rarr;</span>
            </div>
          </a>
        {%- endunless -%}
      {%- else -%}
        <p style="grid-column:1/-1;padding:40px 0;color:rgba(242,237,225,0.5);">No collections yet.</p>
      {%- endfor -%}
    </div>
  </div>

  <footer class="hhl-ft">
    <div class="hhl-ft-grid">
      <div>{%- if settings.logo != blank -%}<img class="hhl-ft-logo" src="{{ settings.logo | image_url: height: 104 }}" alt="{{ shop.name }}">{%- else -%}<div class="hhl-ft-logo"><span style="font-family:'Playfair Display',serif;font-size:22px;letter-spacing:0.15em;color:#f2ede1;">HUMBLE HEARTED</span></div>{%- endif -%}<p style="font-size:11px;color:rgba(242,237,225,0.35);line-height:1.8;max-width:230px;font-weight:300;">Luxury for the real. Crafted for people with beautiful hearts.</p></div>
      <div class="col"><h5>Shop</h5><a href="/collections/necklaces">Necklaces</a><a href="/collections/rings">Rings</a><a href="/collections/bracelets">Bracelets</a><a href="/collections/earrings">Earrings</a></div>
      <div class="col"><h5>Help</h5><a href="#">FAQs</a><a href="#">Shipping</a><a href="#">Returns</a></div>
      <div class="col"><h5>About</h5><a href="#">Our Story</a><a href="#">Sustainability</a></div>
    </div>
    <div class="hhl-ft-bot"><p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All Rights Reserved.</p><span>Visa &middot; Mastercard &middot; Amex &middot; Shop Pay &middot; Apple Pay</span></div>
  </footer>
</div>

<div id="hhlMenu" style="position:fixed;inset:0;z-index:999;background:#080808;display:flex;flex-direction:column;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.35s ease;padding:40px 24px;">
  <button onclick="document.getElementById('hhlMenu').style.cssText='opacity:0;pointer-events:none'" style="position:absolute;top:20px;right:20px;background:none;border:none;cursor:pointer;color:#f2ede1;font-size:32px;">&times;</button>
  <a href="/collections/necklaces" style="font-family:'Playfair Display',serif;font-size:26px;color:#f2ede1;margin-bottom:16px;">Necklaces</a>
  <a href="/collections/rings" style="font-family:'Playfair Display',serif;font-size:26px;color:#f2ede1;margin-bottom:16px;">Rings</a>
  <a href="/collections/bracelets" style="font-family:'Playfair Display',serif;font-size:26px;color:#f2ede1;margin-bottom:16px;">Bracelets</a>
  <a href="/collections/earrings" style="font-family:'Playfair Display',serif;font-size:26px;color:#f2ede1;margin-bottom:16px;">Earrings</a>
  <a href="/collections" style="font-size:13px;letter-spacing:0.18em;color:#C4A843;text-transform:uppercase;font-weight:700;margin-bottom:11px;">Collections</a>
  <a href="/collections/all?sort_by=created-descending" style="font-size:13px;letter-spacing:0.18em;color:#f2ede1;text-transform:uppercase;font-weight:700;margin-bottom:11px;">New</a>
  <a href="/collections/gifts" style="font-size:13px;letter-spacing:0.18em;color:#f2ede1;text-transform:uppercase;font-weight:700;">Gifts</a>
</div>

{% schema %}
{
  "name": "HH Collections List",
  "settings": [
    { "type": "header", "content": "Announcement Bar" },
    { "type": "text", "id": "announcement_text", "label": "Announcement text", "default": "Free Shipping On Orders $75+ ✦ Sign Up For 10% Off ✦ New: Summer Heart Collection ✦ 60-Day Returns" },
    { "type": "header", "content": "Page Header" },
    { "type": "image_picker", "id": "hero_image", "label": "Header background image", "info": "Optional. Falls back to the dark pattern." },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow", "default": "Explore" },
    { "type": "text", "id": "hero_heading", "label": "Heading", "default": "Collections" },
    { "type": "text", "id": "hero_sub", "label": "Subheading", "default": "Shop every Humble Hearted collection" }
  ]
}
{% endschema %}
