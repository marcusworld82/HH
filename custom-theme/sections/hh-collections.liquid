{%- comment -%}
  Humble Hearted — Collections Landing Page
  Matches hh-earrings-collection.liquid structure exactly.
  Used by list-collections.hh.liquid template at /collections.
{%- endcomment -%}

{%- style -%}
  .hhc *,.hhc *::before,.hhc *::after{margin:0;padding:0;box-sizing:border-box;}
  .hhc{background:#080808;color:#f2ede1;font-family:'Montserrat',sans-serif;overflow-x:hidden;}
  .hhc a{color:inherit;text-decoration:none;}
  @keyframes hh-marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
  .hhc-ann{background:#C4A843;overflow:hidden;height:36px;display:flex;align-items:center;}
  .hhc-ann-track{display:flex;animation:hh-marquee 36s linear infinite;white-space:nowrap;will-change:transform;}
  .hhc-ann-track span{font-size:10px;font-weight:700;letter-spacing:0.2em;color:#080808;padding:0 32px;text-transform:uppercase;}
  .hhc-nav{background:#080808;border-bottom:1px solid #1a1510;position:sticky;top:0;z-index:200;}
  .hhc-hn{max-width:1440px;margin:0 auto;padding:0 48px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;height:80px;}
  .hhc-link{font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#f2ede1;}
  .hhc-link.active{color:#C4A843;font-weight:700;}
  .hhc-l{display:flex;gap:24px;align-items:center;}
  .hhc-r{display:flex;gap:18px;align-items:center;}
  .hhc-logo{justify-self:center;line-height:0;}
  .hhc-logo img{height:62px;width:auto;display:block;}
  .hhc-logo span{font-family:'Playfair Display',serif;font-size:26px;color:#f2ede1;letter-spacing:0.15em;}
  .hhc-ic{display:flex;gap:14px;align-items:center;border-left:1px solid #1f1a14;padding-left:16px;margin-left:2px;}
  .hhc-hbg{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:8px;}
  .hhc-hbg span{display:block;width:22px;height:2px;background:#f2ede1;border-radius:1px;}
  .hhc-hero{height:280px;position:relative;overflow:hidden;background:repeating-linear-gradient(45deg,#100a14 0,#100a14 18px,#180f1e 18px,#180f1e 36px);}
  .hhc-hero-inner{position:absolute;inset:0;background:rgba(8,8,8,0.5);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:24px;}
  .hhc-hero-eyebrow{font-size:10px;letter-spacing:0.3em;color:#C4A843;margin-bottom:12px;font-weight:700;text-transform:uppercase;}
  .hhc-hero-title{font-family:'Playfair Display',serif;font-size:56px;color:#f2ede1;font-weight:400;margin-bottom:12px;}
  .hhc-hero-sub{font-size:12px;color:rgba(242,237,225,0.45);font-weight:300;letter-spacing:0.08em;}
  .hhc-cat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:3px;max-width:1440px;margin:40px auto;padding:0 48px;}
  .hhc-cat{position:relative;overflow:hidden;cursor:pointer;aspect-ratio:4/3;display:block;}
  .hhc-cat-img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.6s ease;}
  .hhc-cat:hover .hhc-cat-img{transform:scale(1.04);}
  .hhc-cat-bg{width:100%;height:100%;display:block;transition:transform 0.6s ease;}
  .hhc-cat:hover .hhc-cat-bg{transform:scale(1.04);}
  .hhc-cat-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(8,8,8,0.78) 0%,rgba(8,8,8,0.18) 55%,transparent 100%);display:flex;flex-direction:column;align-items:flex-start;justify-content:flex-end;padding:32px;}
  .hhc-cat-eyebrow{font-size:9px;letter-spacing:0.25em;color:#C4A843;text-transform:uppercase;font-weight:700;margin-bottom:8px;}
  .hhc-cat-title{font-family:'Playfair Display',serif;font-size:32px;color:#f2ede1;font-weight:400;margin-bottom:10px;line-height:1.1;}
  .hhc-cat-cta{font-size:10px;letter-spacing:0.2em;color:#C4A843;text-transform:uppercase;font-weight:700;display:flex;align-items:center;gap:8px;}
  .hhc-cat-cta::after{content:'→';transition:transform 0.3s ease;}
  .hhc-cat:hover .hhc-cat-cta::after{transform:translateX(5px);}
  .hhc-promise{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:#1a1510;border-top:1px solid #1a1510;border-bottom:1px solid #1a1510;margin:0 0 0 0;}
  .hhc-promise-item{background:#080808;padding:24px 32px;text-align:center;}
  .hhc-promise-label{font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:#C4A843;font-weight:700;margin-bottom:5px;}
  .hhc-promise-desc{font-size:11px;color:rgba(242,237,225,0.4);font-weight:300;}
  .hhc-ft{background:#080808;padding:48px 48px 28px;border-top:1px solid #1a1510;}
  .hhc-ft-inner{max-width:1440px;margin:0 auto;}
  .hhc-ft-cols{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:36px;margin-bottom:36px;padding-bottom:36px;border-bottom:1px solid #1a1510;}
  .hhc-ft-tag{font-size:11px;color:rgba(242,237,225,0.35);line-height:1.8;max-width:220px;font-weight:300;}
  .hhc-ft-h{font-size:10px;letter-spacing:0.16em;color:#f2ede1;text-transform:uppercase;font-weight:700;margin-bottom:14px;}
  .hhc-ft-list{display:flex;flex-direction:column;gap:9px;}
  .hhc-ft-list a{font-size:12px;color:rgba(242,237,225,0.4);font-weight:300;}
  .hhc-ft-logo{height:52px;width:auto;display:block;margin-bottom:12px;}
  .hhc-ft-logo span{font-family:'Playfair Display',serif;font-size:22px;color:#f2ede1;letter-spacing:0.15em;}
  .hhc-ft-bottom{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;}
  .hhc-ft-copy{font-size:11px;color:rgba(242,237,225,0.2);font-weight:300;}
  .hhc-ft-pay{font-size:10px;color:rgba(242,237,225,0.2);}
  @media(max-width:1024px){.hhc-cat-grid{padding:28px;}.hhc-ft-cols{grid-template-columns:repeat(3,1fr);}}
  @media(max-width:768px){.hhc-hbg{display:flex!important;}.hhc-l,.hhc-r,.hhc-ic{display:none!important;}.hhc-hn{grid-template-columns:auto 1fr auto!important;padding:0 18px!important;height:60px!important;}.hhc-logo img{height:46px!important;}.hhc-hero-title{font-size:40px;}.hhc-cat-grid{grid-template-columns:1fr;gap:3px;padding:18px;}.hhc-cat{aspect-ratio:3/2;}.hhc-promise{grid-template-columns:repeat(2,1fr);}.hhc-ft-cols{grid-template-columns:repeat(2,1fr);}}
{%- endstyle -%}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

{%- assign logo_url = 'hh-logo.png' | asset_url -%}

{%- assign cat_necklaces = collections['necklaces'] -%}
{%- assign cat_rings      = collections['rings'] -%}
{%- assign cat_bracelets  = collections['bracelets'] -%}
{%- assign cat_earrings   = collections['earrings'] -%}

<div class="hhc">

  <div class="hhc-ann">
    <div class="hhc-ann-track">
      <span>Free Shipping On Orders $75+ &nbsp;&#10022;&nbsp; Sign Up For 10% Off &nbsp;&#10022;&nbsp; New: Summer Heart Collection &nbsp;&#10022;&nbsp; 60-Day Returns &nbsp;&#10022;&nbsp; Free Shipping On Orders $75+ &nbsp;&#10022;&nbsp; Sign Up For 10% Off &nbsp;&#10022;&nbsp; 60-Day Returns &nbsp;&#10022;&nbsp;</span>
    </div>
  </div>

  <nav class="hhc-nav">
    <div class="hhc-hn">
      <button class="hhc-hbg" aria-label="Menu"><span></span><span></span><span></span></button>
      <div class="hhc-l">
        <a class="hhc-link" href="/collections/necklaces">Necklaces</a>
        <a class="hhc-link" href="/collections/rings">Rings</a>
        <a class="hhc-link" href="/collections/bracelets">Bracelets</a>
        <a class="hhc-link" href="/collections/earrings">Earrings</a>
      </div>
      <a class="hhc-logo" href="/">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: height: 124 }}" alt="{{ shop.name }}">
        {%- else -%}
          <img src="{{ logo_url }}" alt="{{ shop.name }}" onerror="this.outerHTML='<span>HH</span>'">
        {%- endif -%}
      </a>
      <div style="display:flex;gap:12px;align-items:center;justify-content:flex-end;">
        <div class="hhc-r">
          <a class="hhc-link active" href="/collections">Collections</a>
          <a class="hhc-link" href="/collections/all?sort_by=created-descending">New</a>
          <a class="hhc-link" href="/collections/all">Gifts</a>
        </div>
        <div class="hhc-ic">
          <a href="/search" aria-label="Search"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path></svg></a>
          <a href="/account" aria-label="Account"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></a>
          <a href="/cart" aria-label="Cart"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg></a>
        </div>
      </div>
    </div>
  </nav>

  <section class="hhc-hero">
    <div class="hhc-hero-inner">
      <p class="hhc-hero-eyebrow">Humble Hearted</p>
      <h1 class="hhc-hero-title">Collections</h1>
      <p class="hhc-hero-sub">Handcrafted Fine Jewelry &middot; 18k Gold Vermeil</p>
    </div>
  </section>

  <div class="hhc-cat-grid">

    <a class="hhc-cat" href="/collections/necklaces">
      {%- if cat_necklaces.image != blank -%}
        <img class="hhc-cat-img" src="{{ cat_necklaces.image | image_url: width: 900 }}" alt="Necklaces" width="900" height="675" loading="lazy">
      {%- else -%}
        <div class="hhc-cat-bg" style="background:repeating-linear-gradient(135deg,#130f0a 0,#130f0a 11px,#1c1610 11px,#1c1610 22px);"></div>
      {%- endif -%}
      <div class="hhc-cat-overlay">
        <p class="hhc-cat-eyebrow">{{ cat_necklaces.products_count | default: 0 }} Pieces</p>
        <h2 class="hhc-cat-title">Necklaces</h2>
        <span class="hhc-cat-cta">Shop Now</span>
      </div>
    </a>

    <a class="hhc-cat" href="/collections/rings">
      {%- if cat_rings.image != blank -%}
        <img class="hhc-cat-img" src="{{ cat_rings.image | image_url: width: 900 }}" alt="Rings" width="900" height="675" loading="lazy">
      {%- else -%}
        <div class="hhc-cat-bg" style="background:repeating-linear-gradient(45deg,#0a0d12 0,#0a0d12 11px,#0f121a 11px,#0f121a 22px);"></div>
      {%- endif -%}
      <div class="hhc-cat-overlay">
        <p class="hhc-cat-eyebrow">{{ cat_rings.products_count | default: 0 }} Pieces</p>
        <h2 class="hhc-cat-title">Rings</h2>
        <span class="hhc-cat-cta">Shop Now</span>
      </div>
    </a>

    <a class="hhc-cat" href="/collections/bracelets">
      {%- if cat_bracelets.image != blank -%}
        <img class="hhc-cat-img" src="{{ cat_bracelets.image | image_url: width: 900 }}" alt="Bracelets" width="900" height="675" loading="lazy">
      {%- else -%}
        <div class="hhc-cat-bg" style="background:repeating-linear-gradient(135deg,#110e07 0,#110e07 11px,#19140a 11px,#19140a 22px);"></div>
      {%- endif -%}
      <div class="hhc-cat-overlay">
        <p class="hhc-cat-eyebrow">{{ cat_bracelets.products_count | default: 0 }} Pieces</p>
        <h2 class="hhc-cat-title">Bracelets</h2>
        <span class="hhc-cat-cta">Shop Now</span>
      </div>
    </a>

    <a class="hhc-cat" href="/collections/earrings">
      {%- if cat_earrings.image != blank -%}
        <img class="hhc-cat-img" src="{{ cat_earrings.image | image_url: width: 900 }}" alt="Earrings" width="900" height="675" loading="lazy">
      {%- else -%}
        <div class="hhc-cat-bg" style="background:repeating-linear-gradient(45deg,#0f0a12 0,#0f0a12 11px,#160f1a 11px,#160f1a 22px);"></div>
      {%- endif -%}
      <div class="hhc-cat-overlay">
        <p class="hhc-cat-eyebrow">{{ cat_earrings.products_count | default: 0 }} Pieces</p>
        <h2 class="hhc-cat-title">Earrings</h2>
        <span class="hhc-cat-cta">Shop Now</span>
      </div>
    </a>

  </div>

  <div class="hhc-promise">
    <div class="hhc-promise-item">
      <p class="hhc-promise-label">Free Shipping</p>
      <p class="hhc-promise-desc">On all orders $75+</p>
    </div>
    <div class="hhc-promise-item">
      <p class="hhc-promise-label">Crafted Quality</p>
      <p class="hhc-promise-desc">18k gold vermeil</p>
    </div>
    <div class="hhc-promise-item">
      <p class="hhc-promise-label">60-Day Returns</p>
      <p class="hhc-promise-desc">Hassle-free returns</p>
    </div>
    <div class="hhc-promise-item">
      <p class="hhc-promise-label">10% Off</p>
      <p class="hhc-promise-desc">Sign up & save today</p>
    </div>
  </div>

  <footer class="hhc-ft">
    <div class="hhc-ft-inner">
      <div class="hhc-ft-cols">
        <div>
          {%- if settings.logo != blank -%}
            <img class="hhc-ft-logo" src="{{ settings.logo | image_url: height: 104 }}" alt="{{ shop.name }}">
          {%- else -%}
            <div class="hhc-ft-logo"><span>HH</span></div>
          {%- endif -%}
          <p class="hhc-ft-tag">Luxury for the real. Crafted for people with beautiful hearts.</p>
        </div>
        <div>
          <h5 class="hhc-ft-h">Shop</h5>
          <div class="hhc-ft-list">
            <a href="/collections/necklaces">Necklaces</a>
            <a href="/collections/rings">Rings</a>
            <a href="/collections/bracelets">Bracelets</a>
            <a href="/collections/earrings">Earrings</a>
          </div>
        </div>
        <div>
          <h5 class="hhc-ft-h">Help</h5>
          <div class="hhc-ft-list">
            <a href="/pages/faqs">FAQs</a>
            <a href="/pages/shipping">Shipping</a>
            <a href="/pages/returns">Returns</a>
          </div>
        </div>
        <div>
          <h5 class="hhc-ft-h">About</h5>
          <div class="hhc-ft-list">
            <a href="/pages/our-story">Our Story</a>
            <a href="/pages/sustainability">Sustainability</a>
          </div>
        </div>
      </div>
      <div class="hhc-ft-bottom">
        <p class="hhc-ft-copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.</p>
        <span class="hhc-ft-pay">Visa &middot; Mastercard &middot; Shop Pay &middot; Apple Pay</span>
      </div>
    </div>
  </footer>

</div>

{% schema %}
{
  "name": "HH Collections",
  "settings": [],
  "presets": [{ "name": "HH Collections" }]
}
{% endschema %}
