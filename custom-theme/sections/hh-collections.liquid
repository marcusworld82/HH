{%- comment -%}
  Humble Hearted — Collections landing page
  Shows all four jewelry categories as full-bleed cards.
  Uses the same dark/gold design system as all other HH pages.
  Assign to template "list-collections.hh" or create a page with this section.
{%- endcomment -%}

{%- style -%}
  .hhcl *,.hhcl *::before,.hhcl *::after{margin:0;padding:0;box-sizing:border-box;}
  .hhcl{background:#080808;color:#f2ede1;font-family:'Montserrat',sans-serif;overflow-x:hidden;}
  .hhcl a{color:inherit;text-decoration:none;}
  @keyframes hh-cl-marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

  /* Announcement bar */
  .hhcl-ann{background:#C4A843;overflow:hidden;height:36px;display:flex;align-items:center;}
  .hhcl-ann-track{display:flex;animation:hh-cl-marquee 36s linear infinite;white-space:nowrap;will-change:transform;}
  .hhcl-ann-track span{font-size:10px;font-weight:700;letter-spacing:0.2em;color:#080808;padding:0 32px;text-transform:uppercase;}

  /* Nav */
  .hhcl-nav{background:#080808;border-bottom:1px solid #1a1510;position:sticky;top:0;z-index:200;}
  .hhcl-hn{max-width:1440px;margin:0 auto;padding:0 48px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;height:80px;}
  .hhcl-link{font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#f2ede1;}
  .hhcl-link.active{color:#C4A843;font-weight:700;}
  .hhcl-l{display:flex;gap:24px;align-items:center;}
  .hhcl-r{display:flex;gap:18px;align-items:center;}
  .hhcl-logo{justify-self:center;line-height:0;}
  .hhcl-logo img{height:62px;width:auto;display:block;}
  .hhcl-logo span{font-family:'Playfair Display',serif;font-size:26px;color:#f2ede1;letter-spacing:0.15em;}
  .hhcl-ic{display:flex;gap:14px;align-items:center;border-left:1px solid #1f1a14;padding-left:16px;margin-left:2px;}
  .hhcl-hbg{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:8px;}
  .hhcl-hbg span{display:block;width:22px;height:2px;background:#f2ede1;border-radius:1px;}

  /* Hero */
  .hhcl-hero{height:280px;position:relative;overflow:hidden;background:repeating-linear-gradient(45deg,#100a14 0,#100a14 18px,#180f1e 18px,#180f1e 36px);}
  .hhcl-hero-inner{position:absolute;inset:0;background:rgba(8,8,8,0.5);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:24px;}
  .hhcl-hero-eyebrow{font-size:10px;letter-spacing:0.3em;color:#C4A843;margin-bottom:12px;font-weight:700;text-transform:uppercase;}
  .hhcl-hero-title{font-family:'Playfair Display',serif;font-size:56px;color:#f2ede1;font-weight:400;margin-bottom:12px;}
  .hhcl-hero-sub{font-size:12px;color:rgba(242,237,225,0.45);font-weight:300;letter-spacing:0.08em;}

  /* Collections grid */
  .hhcl-body{max-width:1440px;margin:0 auto;padding:56px 48px 72px;}
  .hhcl-intro{text-align:center;margin-bottom:52px;}
  .hhcl-intro-eyebrow{font-size:9px;letter-spacing:0.3em;color:#C4A843;font-weight:700;text-transform:uppercase;margin-bottom:10px;}
  .hhcl-intro-text{font-family:'Playfair Display',serif;font-size:28px;color:#f2ede1;font-weight:400;line-height:1.35;}

  /* 2x2 grid with featured top card */
  .hhcl-grid{display:grid;grid-template-columns:1fr 1fr;grid-template-rows:480px 480px;gap:16px;}
  .hhcl-item{position:relative;overflow:hidden;display:block;cursor:pointer;}
  .hhcl-item-bg{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform 0.6s cubic-bezier(0.16,1,0.3,1);}
  .hhcl-item:hover .hhcl-item-bg{transform:scale(1.04);}
  .hhcl-item-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(8,8,8,0.82) 0%,rgba(8,8,8,0.2) 50%,rgba(8,8,8,0.05) 100%);}
  .hhcl-item-content{position:absolute;bottom:0;left:0;right:0;padding:32px;}
  .hhcl-item-eyebrow{font-size:9px;letter-spacing:0.25em;color:#C4A843;font-weight:700;text-transform:uppercase;margin-bottom:8px;}
  .hhcl-item-name{font-family:'Playfair Display',serif;font-size:34px;color:#f2ede1;font-weight:400;line-height:1.15;margin-bottom:10px;}
  .hhcl-item-meta{font-size:11px;color:rgba(242,237,225,0.45);letter-spacing:0.06em;font-weight:300;margin-bottom:18px;}
  .hhcl-item-cta{display:inline-flex;align-items:center;gap:8px;font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#C4A843;border-bottom:1px solid rgba(196,168,67,0.35);padding-bottom:3px;transition:gap 0.25s ease,border-color 0.25s ease;}
  .hhcl-item:hover .hhcl-item-cta{gap:14px;border-color:#C4A843;}
  .hhcl-item-cta svg{flex-shrink:0;}

  /* Fallback geometric backgrounds per category */
  .hhcl-bg-necklaces{background:repeating-linear-gradient(135deg,#130f0a 0,#130f0a 11px,#1c1610 11px,#1c1610 22px);}
  .hhcl-bg-rings{background:repeating-linear-gradient(45deg,#0a0d12 0,#0a0d12 11px,#0f121a 11px,#0f121a 22px);}
  .hhcl-bg-bracelets{background:repeating-linear-gradient(135deg,#110e07 0,#110e07 11px,#19140a 11px,#19140a 22px);}
  .hhcl-bg-earrings{background:repeating-linear-gradient(45deg,#0f0a12 0,#0f0a12 11px,#160f1a 11px,#160f1a 22px);}

  /* Gold accent line on hover */
  .hhcl-item::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:#C4A843;transform:scaleX(0);transform-origin:left;transition:transform 0.4s cubic-bezier(0.16,1,0.3,1);}
  .hhcl-item:hover::after{transform:scaleX(1);}

  /* Divider strip */
  .hhcl-divider{border:none;border-top:1px solid #1a1510;margin:0 48px;}

  /* Promise strip */
  .hhcl-promise{max-width:1440px;margin:0 auto;padding:40px 48px;display:grid;grid-template-columns:repeat(4,1fr);gap:24px;border-top:1px solid #1a1510;}
  .hhcl-promise-item{display:flex;flex-direction:column;align-items:center;text-align:center;gap:10px;}
  .hhcl-promise-icon{color:#C4A843;}
  .hhcl-promise-title{font-size:10px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#f2ede1;}
  .hhcl-promise-text{font-size:11px;color:rgba(242,237,225,0.4);font-weight:300;line-height:1.6;}

  /* Footer */
  .hhcl-ft{background:#080808;padding:48px 48px 28px;border-top:1px solid #1a1510;}
  .hhcl-ft-inner{max-width:1440px;margin:0 auto;}
  .hhcl-ft-cols{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:36px;margin-bottom:36px;padding-bottom:36px;border-bottom:1px solid #1a1510;}
  .hhcl-ft-tag{font-size:11px;color:rgba(242,237,225,0.35);line-height:1.8;max-width:220px;font-weight:300;}
  .hhcl-ft-h{font-size:10px;letter-spacing:0.16em;color:#f2ede1;text-transform:uppercase;font-weight:700;margin-bottom:14px;}
  .hhcl-ft-list{display:flex;flex-direction:column;gap:9px;}
  .hhcl-ft-list a{font-size:12px;color:rgba(242,237,225,0.4);font-weight:300;}
  .hhcl-ft-logo{height:52px;width:auto;display:block;margin-bottom:12px;}
  .hhcl-ft-logo span{font-family:'Playfair Display',serif;font-size:22px;color:#f2ede1;letter-spacing:0.15em;}
  .hhcl-ft-bottom{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;}
  .hhcl-ft-copy{font-size:11px;color:rgba(242,237,225,0.2);font-weight:300;}
  .hhcl-ft-pay{font-size:10px;color:rgba(242,237,225,0.2);}

  /* Responsive */
  @media(max-width:1024px){
    .hhcl-grid{grid-template-rows:400px 400px;}
    .hhcl-ft-cols{grid-template-columns:repeat(3,1fr);}
    .hhcl-promise{grid-template-columns:repeat(2,1fr);}
  }
  @media(max-width:768px){
    .hhcl-hbg{display:flex!important;}
    .hhcl-l,.hhcl-r,.hhcl-ic{display:none!important;}
    .hhcl-hn{grid-template-columns:auto 1fr auto!important;padding:0 18px!important;height:60px!important;}
    .hhcl-logo img{height:46px!important;}
    .hhcl-hero-title{font-size:40px;}
    .hhcl-grid{grid-template-columns:1fr;grid-template-rows:auto;gap:10px;}
    .hhcl-item{height:360px;}
    .hhcl-body{padding:36px 18px 52px;}
    .hhcl-item-name{font-size:26px;}
    .hhcl-ft-cols{grid-template-columns:repeat(2,1fr);}
    .hhcl-promise{grid-template-columns:repeat(2,1fr);padding:32px 18px;}
    .hhcl-divider{margin:0 18px;}
  }
{%- endstyle -%}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

{%- assign logo_url = 'hh-logo.png' | asset_url -%}

{%- comment -%} Grab each collection by handle for live product counts {%- endcomment -%}
{%- assign col_necklaces  = collections['necklaces']  -%}
{%- assign col_rings      = collections['rings']      -%}
{%- assign col_bracelets  = collections['bracelets']  -%}
{%- assign col_earrings   = collections['earrings']   -%}

<div class="hhcl">

  <!-- Announcement bar -->
  <div class="hhcl-ann">
    <div class="hhcl-ann-track">
      <span>Free Shipping On Orders $75+ &nbsp;&#10022;&nbsp; Sign Up For 10% Off &nbsp;&#10022;&nbsp; New: Summer Heart Collection &nbsp;&#10022;&nbsp; 60-Day Returns &nbsp;&#10022;&nbsp; Free Shipping On Orders $75+ &nbsp;&#10022;&nbsp; Sign Up For 10% Off &nbsp;&#10022;&nbsp; 60-Day Returns &nbsp;&#10022;&nbsp;</span>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="hhcl-nav">
    <div class="hhcl-hn">
      <button class="hhcl-hbg" aria-label="Menu"><span></span><span></span><span></span></button>
      <div class="hhcl-l">
        <a class="hhcl-link" href="/collections/necklaces">Necklaces</a>
        <a class="hhcl-link" href="/collections/rings">Rings</a>
        <a class="hhcl-link" href="/collections/bracelets">Bracelets</a>
        <a class="hhcl-link" href="/collections/earrings">Earrings</a>
      </div>
      <a class="hhcl-logo" href="/">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: height: 124 }}" alt="{{ shop.name }}">
        {%- else -%}
          <img src="{{ logo_url }}" alt="{{ shop.name }}" onerror="this.outerHTML='<span>HH</span>'">
        {%- endif -%}
      </a>
      <div style="display:flex;gap:12px;align-items:center;justify-content:flex-end;">
        <div class="hhcl-r">
          <a class="hhcl-link active" href="/collections">Collections</a>
          <a class="hhcl-link" href="/collections/all?sort_by=created-descending">New</a>
          <a class="hhcl-link" href="/collections/all">Gifts</a>
        </div>
        <div class="hhcl-ic">
          <a href="/search" aria-label="Search"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path></svg></a>
          <a href="/account" aria-label="Account"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></a>
          <a href="/cart" aria-label="Cart"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg></a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hhcl-hero">
    <div class="hhcl-hero-inner">
      <p class="hhcl-hero-eyebrow">Shop by Category</p>
      <h1 class="hhcl-hero-title">Collections</h1>
      <p class="hhcl-hero-sub">Necklaces &middot; Rings &middot; Bracelets &middot; Earrings</p>
    </div>
  </section>

  <!-- Body -->
  <div class="hhcl-body">
    <div class="hhcl-intro">
      <p class="hhcl-intro-eyebrow">Humble Hearted</p>
      <p class="hhcl-intro-text">Every piece is crafted for people with beautiful hearts.</p>
    </div>

    <div class="hhcl-grid">

      <!-- Necklaces -->
      <a class="hhcl-item" href="/collections/necklaces">
        <div class="hhcl-item-bg hhcl-bg-necklaces"
          {%- if col_necklaces.image -%}
            style="background-image:url('{{ col_necklaces.image | image_url: width: 900 }}');"
          {%- endif -%}>
        </div>
        <div class="hhcl-item-overlay"></div>
        <div class="hhcl-item-content">
          <p class="hhcl-item-eyebrow">Layer &amp; Stack</p>
          <h2 class="hhcl-item-name">Necklaces</h2>
          <p class="hhcl-item-meta">{%- if col_necklaces.products_count > 0 -%}{{ col_necklaces.products_count }} Pieces &middot; {%- endif -%}18k Gold Vermeil</p>
          <span class="hhcl-item-cta">Shop Now <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>

      <!-- Rings -->
      <a class="hhcl-item" href="/collections/rings">
        <div class="hhcl-item-bg hhcl-bg-rings"
          {%- if col_rings.image -%}
            style="background-image:url('{{ col_rings.image | image_url: width: 900 }}');"
          {%- endif -%}>
        </div>
        <div class="hhcl-item-overlay"></div>
        <div class="hhcl-item-content">
          <p class="hhcl-item-eyebrow">Everyday Elegance</p>
          <h2 class="hhcl-item-name">Rings</h2>
          <p class="hhcl-item-meta">{%- if col_rings.products_count > 0 -%}{{ col_rings.products_count }} Pieces &middot; {%- endif -%}18k Gold Vermeil</p>
          <span class="hhcl-item-cta">Shop Now <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>

      <!-- Bracelets -->
      <a class="hhcl-item" href="/collections/bracelets">
        <div class="hhcl-item-bg hhcl-bg-bracelets"
          {%- if col_bracelets.image -%}
            style="background-image:url('{{ col_bracelets.image | image_url: width: 900 }}');"
          {%- endif -%}>
        </div>
        <div class="hhcl-item-overlay"></div>
        <div class="hhcl-item-content">
          <p class="hhcl-item-eyebrow">Wrist Candy</p>
          <h2 class="hhcl-item-name">Bracelets</h2>
          <p class="hhcl-item-meta">{%- if col_bracelets.products_count > 0 -%}{{ col_bracelets.products_count }} Pieces &middot; {%- endif -%}18k Gold Vermeil</p>
          <span class="hhcl-item-cta">Shop Now <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>

      <!-- Earrings -->
      <a class="hhcl-item" href="/collections/earrings">
        <div class="hhcl-item-bg hhcl-bg-earrings"
          {%- if col_earrings.image -%}
            style="background-image:url('{{ col_earrings.image | image_url: width: 900 }}');"
          {%- endif -%}>
        </div>
        <div class="hhcl-item-overlay"></div>
        <div class="hhcl-item-content">
          <p class="hhcl-item-eyebrow">Statement Pieces</p>
          <h2 class="hhcl-item-name">Earrings</h2>
          <p class="hhcl-item-meta">{%- if col_earrings.products_count > 0 -%}{{ col_earrings.products_count }} Pieces &middot; {%- endif -%}18k Gold Vermeil</p>
          <span class="hhcl-item-cta">Shop Now <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>

    </div>
  </div>

  <!-- Promise strip -->
  <div class="hhcl-promise">
    <div class="hhcl-promise-item">
      <span class="hhcl-promise-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
      <p class="hhcl-promise-title">Free Shipping</p>
      <p class="hhcl-promise-text">On all orders $75 and over</p>
    </div>
    <div class="hhcl-promise-item">
      <span class="hhcl-promise-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
      <p class="hhcl-promise-title">Quality Guaranteed</p>
      <p class="hhcl-promise-text">18k gold vermeil on every piece</p>
    </div>
    <div class="hhcl-promise-item">
      <span class="hhcl-promise-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span>
      <p class="hhcl-promise-title">60-Day Returns</p>
      <p class="hhcl-promise-text">Hassle-free return policy</p>
    </div>
    <div class="hhcl-promise-item">
      <span class="hhcl-promise-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></span>
      <p class="hhcl-promise-title">10% Off</p>
      <p class="hhcl-promise-text">Sign up to unlock your discount</p>
    </div>
  </div>

  <!-- Footer -->
  <footer class="hhcl-ft">
    <div class="hhcl-ft-inner">
      <div class="hhcl-ft-cols">
        <div>
          {%- if settings.logo != blank -%}
            <img class="hhcl-ft-logo" src="{{ settings.logo | image_url: height: 104 }}" alt="{{ shop.name }}">
          {%- else -%}
            <div class="hhcl-ft-logo"><span>HH</span></div>
          {%- endif -%}
          <p class="hhcl-ft-tag">Luxury for the real. Crafted for people with beautiful hearts.</p>
        </div>
        <div>
          <h5 class="hhcl-ft-h">Shop</h5>
          <div class="hhcl-ft-list">
            <a href="/collections/necklaces">Necklaces</a>
            <a href="/collections/rings">Rings</a>
            <a href="/collections/bracelets">Bracelets</a>
            <a href="/collections/earrings">Earrings</a>
          </div>
        </div>
        <div>
          <h5 class="hhcl-ft-h">Help</h5>
          <div class="hhcl-ft-list">
            <a href="/pages/faqs">FAQs</a>
            <a href="/pages/shipping">Shipping</a>
            <a href="/pages/returns">Returns</a>
          </div>
        </div>
        <div>
          <h5 class="hhcl-ft-h">About</h5>
          <div class="hhcl-ft-list">
            <a href="/pages/our-story">Our Story</a>
            <a href="/pages/sustainability">Sustainability</a>
          </div>
        </div>
      </div>
      <div class="hhcl-ft-bottom">
        <p class="hhcl-ft-copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.</p>
        <span class="hhcl-ft-pay">Visa &middot; Mastercard &middot; Shop Pay &middot; Apple Pay</span>
      </div>
    </div>
  </footer>

</div>

