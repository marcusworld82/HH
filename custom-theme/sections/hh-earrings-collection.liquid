{%- comment -%}
  Humble Hearted — dark/gold collection design
  Ported from Earrings.dc.html. Renders the assigned collection's real products.
  Assign a collection to template "collection.hh-earrings" to use this.
{%- endcomment -%}

{%- style -%}
  .hhc *,.hhc *::before,.hhc *::after{margin:0;padding:0;box-sizing:border-box;}
  .hhc{background:#080808;color:#f2ede1;font-family:'Montserrat',sans-serif;overflow-x:hidden;}
  .hhc a{color:inherit;text-decoration:none;}
  @keyframes hh-marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
  .hhc-ann{background:#C4A843;overflow:hidden;height:36px;display:flex;align-items:center;}
  .hhc-ann-track{display:flex;animation:hh-marquee 36s linear infinite;white-space:nowrap;will-change:transform;}
  .hhc-ann-track span{font-size:10px;font-weight:700;letter-spacing:0.2em;color:#080808;padding:0 32px;text-transform:uppercase;}
  .hhc-nav{background:#080808;border-bottom:1px solid #1a1510;position:sticky;top:0;z-index:200;}
  .hhc-hn{max-width:1440px;margin:0 auto;padding:0 48px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;height:80px;}
  .hhc-link{font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#f2ede1;}
  .hhc-link.active{color:#C4A843;font-weight:700;}
  .hhc-l{display:flex;gap:24px;align-items:center;}
  .hhc-r{display:flex;gap:18px;align-items:center;}
  .hhc-logo{justify-self:center;line-height:0;}
  .hhc-logo img{height:62px;width:auto;display:block;}
  .hhc-logo span{font-family:'Playfair Display',serif;font-size:26px;color:#f2ede1;letter-spacing:0.15em;}
  .hhc-ic{display:flex;gap:14px;align-items:center;border-left:1px solid #1f1a14;padding-left:16px;margin-left:2px;}
  .hhc-hbg{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:8px;}
  .hhc-hbg span{display:block;width:22px;height:2px;background:#f2ede1;border-radius:1px;}
  .hhc-hero{height:280px;position:relative;overflow:hidden;background:repeating-linear-gradient(45deg,#100a14 0,#100a14 18px,#180f1e 18px,#180f1e 36px);}
  .hhc-hero-inner{position:absolute;inset:0;background:rgba(8,8,8,0.5);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:24px;}
  .hhc-hero-eyebrow{font-size:10px;letter-spacing:0.3em;color:#C4A843;margin-bottom:12px;font-weight:700;text-transform:uppercase;}
  .hhc-hero-title{font-family:'Playfair Display',serif;font-size:56px;color:#f2ede1;font-weight:400;margin-bottom:12px;}
  .hhc-hero-sub{font-size:12px;color:rgba(242,237,225,0.45);font-weight:300;letter-spacing:0.08em;}
  .hhc-filter{border-bottom:1px solid #1a1510;padding:14px 48px;}
  .hhc-filter-inner{max-width:1440px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;}
  .hhc-chips{display:flex;gap:9px;flex-wrap:wrap;align-items:center;}
  .hhc-chip{padding:7px 14px;font-size:9px;letter-spacing:0.12em;text-transform:uppercase;cursor:pointer;}
  .hhc-chip.active{background:#C4A843;color:#080808;font-weight:700;border:1px solid #C4A843;}
  .hhc-chip.idle{background:transparent;color:rgba(242,237,225,0.5);font-weight:600;border:1px solid rgba(242,237,225,0.2);}
  .hhc-sort{font-size:11px;color:rgba(242,237,225,0.45);font-weight:300;}
  .hhc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:28px;max-width:1440px;margin:0 auto;padding:40px 48px 16px;}
  .hhc-card{cursor:pointer;display:block;}
  .hhc-card-img{position:relative;overflow:hidden;transition:transform 0.4s ease;aspect-ratio:1;margin-bottom:14px;background-size:cover;background-position:center;}
  .hhc-card:hover .hhc-card-img{transform:scale(1.02);}
  .hhc-badge{position:absolute;top:10px;left:10px;color:#fff;font-size:9px;font-weight:700;padding:4px 8px;letter-spacing:0.1em;text-transform:uppercase;}
  .hhc-qa{opacity:0;transition:opacity 0.3s;position:absolute;bottom:0;left:0;right:0;background:#080808;color:#C4A843;font-size:9px;font-weight:700;letter-spacing:0.15em;padding:11px;text-align:center;text-transform:uppercase;border-top:1px solid #1f1f1f;}
  .hhc-card:hover .hhc-qa{opacity:1;}
  .hhc-mat{font-size:9px;color:#C4A843;letter-spacing:0.12em;margin-bottom:5px;font-weight:700;text-transform:uppercase;}
  .hhc-name{font-family:'Playfair Display',serif;font-size:16px;color:#f2ede1;margin-bottom:7px;line-height:1.3;font-weight:400;}
  .hhc-pr{display:flex;gap:8px;align-items:center;}
  .hhc-price{font-size:14px;color:#f2ede1;font-weight:600;}
  .hhc-orig{font-size:12px;color:rgba(242,237,225,0.35);text-decoration:line-through;}
  .hhc-loadwrap{text-align:center;padding:16px 48px 64px;}
  .hhc-load{padding:14px 48px;background:transparent;border:1px solid rgba(196,168,67,0.4);color:#C4A843;font-size:10px;letter-spacing:0.2em;font-weight:700;text-transform:uppercase;cursor:pointer;}
  .hhc-ft{background:#080808;padding:48px 48px 28px;border-top:1px solid #1a1510;}
  .hhc-ft-inner{max-width:1440px;margin:0 auto;}
  .hhc-ft-cols{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:36px;margin-bottom:36px;padding-bottom:36px;border-bottom:1px solid #1a1510;}
  .hhc-ft-tag{font-size:11px;color:rgba(242,237,225,0.35);line-height:1.8;max-width:220px;font-weight:300;}
  .hhc-ft-h{font-size:10px;letter-spacing:0.16em;color:#f2ede1;text-transform:uppercase;font-weight:700;margin-bottom:14px;}
  .hhc-ft-list{display:flex;flex-direction:column;gap:9px;}
  .hhc-ft-list a{font-size:12px;color:rgba(242,237,225,0.4);font-weight:300;}
  .hhc-ft-logo{height:52px;width:auto;display:block;margin-bottom:12px;}
  .hhc-ft-logo span{font-family:'Playfair Display',serif;font-size:22px;color:#f2ede1;letter-spacing:0.15em;}
  .hhc-ft-bottom{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;}
  .hhc-ft-copy{font-size:11px;color:rgba(242,237,225,0.2);font-weight:300;}
  .hhc-ft-pay{font-size:10px;color:rgba(242,237,225,0.2);}
  @media(max-width:1024px){.hhc-grid{grid-template-columns:repeat(3,1fr);padding:32px 28px 12px;}.hhc-ft-cols{grid-template-columns:repeat(3,1fr);}}
  @media(max-width:768px){.hhc-hbg{display:flex!important;}.hhc-l,.hhc-r,.hhc-ic{display:none!important;}.hhc-hn{grid-template-columns:auto 1fr auto!important;padding:0 18px!important;height:60px!important;}.hhc-logo img{height:46px!important;}.hhc-hero-title{font-size:40px;}.hhc-grid{grid-template-columns:repeat(2,1fr);gap:14px;padding:24px 18px 8px;}.hhc-ft-cols{grid-template-columns:repeat(2,1fr);}}
{%- endstyle -%}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

{%- assign logo_url = 'hh-logo.png' | asset_url -%}
{%- assign bgs = 'repeating-linear-gradient(135deg,#130f0a 0,#130f0a 11px,#1c1610 11px,#1c1610 22px)|repeating-linear-gradient(45deg,#0a0d12 0,#0a0d12 11px,#0f121a 11px,#0f121a 22px)|repeating-linear-gradient(135deg,#110e07 0,#110e07 11px,#19140a 11px,#19140a 22px)|repeating-linear-gradient(45deg,#0f0a12 0,#0f0a12 11px,#160f1a 11px,#160f1a 22px)' | split: '|' -%}

<div class="hhc">
  <div class="hhc-ann">
    <div class="hhc-ann-track">
      <span>{{ section.settings.announcement_text }} &nbsp;&#10022;&nbsp; {{ section.settings.announcement_text }} &nbsp;&#10022;&nbsp;</span>
    </div>
  </div>

  <nav class="hhc-nav">
    <div class="hhc-hn">
      <button class="hhc-hbg" aria-label="Menu"><span></span><span></span><span></span></button>
      <div class="hhc-l">
        <a class="hhc-link{% if collection.handle == 'necklaces' %} active{% endif %}" href="/collections/necklaces">Necklaces</a>
        <a class="hhc-link{% if collection.handle == 'rings' %} active{% endif %}" href="/collections/rings">Rings</a>
        <a class="hhc-link{% if collection.handle == 'bracelets' %} active{% endif %}" href="/collections/bracelets">Bracelets</a>
        <a class="hhc-link{% if collection.handle == 'earrings' %} active{% endif %}" href="/collections/earrings">Earrings</a>
      </div>
      <a class="hhc-logo" href="/">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: height: 124 }}" alt="{{ shop.name }}">
        {%- else -%}
          <img src="{{ logo_url }}" alt="{{ shop.name }}" onerror="this.outerHTML='<span>HH</span>'">
        {%- endif -%}
      </a>
      <div style="display:flex;gap:12px;align-items:center;justify-content:flex-end;">
        <div class="hhc-r">
          <a class="hhc-link{% if collection.handle == 'pendants' %} active{% endif %}" href="/collections/pendants">Pendants</a>
          <a class="hhc-link{% if collection.handle == 'all' %} active{% endif %}" href="/collections/all?sort_by=created-descending">New</a>
          <a class="hhc-link{% if collection.handle == 'gifts' %} active{% endif %}" href="/collections/gifts">Gifts</a>
        </div>
        <div class="hhc-ic">
          <a href="/search" aria-label="Search"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path></svg></a>
          <a href="/account" aria-label="Account"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></a>
          <a href="/cart" aria-label="Cart"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg></a>
        </div>
      </div>
    </div>
  </nav>

  <section class="hhc-hero" style="{% if section.settings.hero_image != blank %}background-image:url('{{ section.settings.hero_image | image_url: width: 1600 }}');background-size:cover;background-position:center;{% endif %}">
    <div class="hhc-hero-inner">
      <p class="hhc-hero-eyebrow">{{ section.settings.hero_eyebrow | default: 'Explore' }}</p>
      <h1 class="hhc-hero-title">{{ collection.title | default: 'Collection' }}</h1>
      <p class="hhc-hero-sub">{{ collection.products_count }} Pieces &middot; {{ section.settings.hero_material | default: '18k Gold Vermeil' }}</p>
    </div>
  </section>

  <div class="hhc-filter">
    <div class="hhc-filter-inner">
      <div class="hhc-chips">
        <span class="hhc-chip active">All</span>
        <a class="hhc-chip idle" href="{{ collection.url }}?filter.p.tag=New">New In</a>
        <span class="hhc-chip idle">Best Sellers</span>
      </div>
      <span class="hhc-sort">Sort: Featured &#9662;</span>
    </div>
  </div>

  <div class="hhc-grid">
    {%- for product in collection.products -%}
      {%- assign bg_index = forloop.index0 | modulo: 4 -%}
      {%- assign bg = bgs[bg_index] -%}
      <a class="hhc-card" href="{{ product.url }}">
        <div class="hhc-card-img" style="{% if product.featured_image %}background-image:url('{{ product.featured_image | image_url: width: 600 }}');{% else %}background:{{ bg }};{% endif %}">
          {%- if product.compare_at_price > product.price -%}
            <span class="hhc-badge" style="background:#8B1818;">Sale</span>
          {%- elsif product.tags contains 'New' -%}
            <span class="hhc-badge" style="background:rgba(139,24,24,0.85);">New In</span>
          {%- endif -%}
          <div class="hhc-qa">+ Quick Add</div>
        </div>
        <p class="hhc-mat">{{ product.type | default: '18k Gold Vermeil' }}</p>
        <p class="hhc-name">{{ product.title }}</p>
        <div class="hhc-pr">
          <span class="hhc-price">{{ product.price | money_without_trailing_zeros }}</span>
          {%- if product.compare_at_price > product.price -%}
            <span class="hhc-orig">{{ product.compare_at_price | money_without_trailing_zeros }}</span>
          {%- endif -%}
        </div>
      </a>
    {%- else -%}
      <p style="padding:40px 48px;color:rgba(242,237,225,0.5);">No products in this collection yet.</p>
    {%- endfor -%}
  </div>

  {%- if paginate.next -%}
    <div class="hhc-loadwrap"><a class="hhc-load" href="{{ paginate.next.url }}">Load More</a></div>
  {%- endif -%}

  <footer class="hhc-ft">
    <div class="hhc-ft-inner">
      <div class="hhc-ft-cols">
        <div>
          {%- if settings.logo != blank -%}
            <img class="hhc-ft-logo" src="{{ settings.logo | image_url: height: 104 }}" alt="{{ shop.name }}">
          {%- else -%}
            <div class="hhc-ft-logo"><span>HH</span></div>
          {%- endif -%}
          <p class="hhc-ft-tag">Luxury for the real. Crafted for people with beautiful hearts.</p>
        </div>
        <div>
          <h5 class="hhc-ft-h">Shop</h5>
          <div class="hhc-ft-list">
            <a href="/collections/necklaces">Necklaces</a>
            <a href="/collections/rings">Rings</a>
            <a href="/collections/bracelets">Bracelets</a>
            <a href="/collections/earrings">Earrings</a>
            <a href="/collections/pendants">Pendants</a>
          </div>
        </div>
        <div>
          <h5 class="hhc-ft-h">Help</h5>
          <div class="hhc-ft-list">
            <a href="/pages/faqs">FAQs</a>
            <a href="/pages/shipping">Shipping</a>
            <a href="/pages/returns">Returns</a>
          </div>
        </div>
        <div>
          <h5 class="hhc-ft-h">About</h5>
          <div class="hhc-ft-list">
            <a href="/pages/our-story">Our Story</a>
            <a href="/pages/sustainability">Sustainability</a>
          </div>
        </div>
      </div>
      <div class="hhc-ft-bottom">
        <p class="hhc-ft-copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.</p>
        <span class="hhc-ft-pay">Visa &middot; Mastercard &middot; Shop Pay &middot; Apple Pay</span>
      </div>
    </div>
  </footer>
</div>

{% schema %}
{
  "name": "HH Collection Page",
  "settings": [
    { "type": "header", "content": "Announcement Bar" },
    { "type": "text", "id": "announcement_text", "label": "Announcement text", "default": "Free Shipping On Orders $75+ ✦ Sign Up For 10% Off ✦ New: Summer Heart Collection ✦ 60-Day Returns" },
    { "type": "header", "content": "Collection Header" },
    { "type": "image_picker", "id": "hero_image", "label": "Header background image", "info": "Optional. Falls back to the dark pattern. The title comes from the collection itself." },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow text", "default": "Explore" },
    { "type": "text", "id": "hero_material", "label": "Subtitle after piece count", "default": "18k Gold Vermeil" }
  ],
  "presets": [{ "name": "HH Collection Page" }]
}
{% endschema %}
