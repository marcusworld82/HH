{%- comment -%}
  Humble Hearted — dynamic product page (ported from Product Page.dc.html).
  Renders real product data: media gallery, variants, add-to-cart, description, related.
  Used as the default product template via templates/product.json + layout hh-standalone.
{%- endcomment -%}
{%- style -%}
  .hhp *,.hhp *::before,.hhp *::after{margin:0;padding:0;box-sizing:border-box;}
  .hhp{background:#080808;color:#f2ede1;font-family:'Montserrat',sans-serif;overflow-x:hidden;}
  .hhp a{color:inherit;text-decoration:none;}
  @keyframes hhp-marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
  .hhp-ann{background:#C4A843;overflow:hidden;height:36px;display:flex;align-items:center;}
  .hhp-ann div{display:flex;animation:hhp-marquee 36s linear infinite;white-space:nowrap;}
  .hhp-ann span{font-size:10px;font-weight:700;letter-spacing:0.2em;color:#080808;padding:0 32px;text-transform:uppercase;}
  .hhp-nav{background:#080808;border-bottom:1px solid #1a1510;position:sticky;top:0;z-index:200;}
  .hhp-hn{max-width:1440px;margin:0 auto;padding:0 48px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;height:80px;}
  .hhp-link{color:#f2ede1;font-size:11px;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;}
  .hhp-l{display:flex;gap:24px;align-items:center;}
  .hhp-r{display:flex;gap:18px;align-items:center;}
  .hhp-logo{justify-self:center;line-height:0;}
  .hhp-logo img{height:62px;width:auto;display:block;}
  .hhp-logo span{font-family:'Playfair Display',serif;font-size:24px;letter-spacing:0.15em;color:#f2ede1;}
  .hhp-ic{display:flex;gap:14px;align-items:center;border-left:1px solid #1f1a14;padding-left:16px;margin-left:2px;}
  .hbg{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:8px;}
  .hbg span{display:block;width:22px;height:2px;background:#f2ede1;border-radius:1px;}
  .hhp-crumb{max-width:1440px;margin:0 auto;padding:14px 48px;display:flex;gap:8px;align-items:center;font-size:11px;color:rgba(242,237,225,0.35);font-weight:300;}
  .hhp-crumb a{color:rgba(242,237,225,0.35);}
  .pg{display:grid;grid-template-columns:55% 1fr;gap:60px;max-width:1440px;margin:0 auto;padding:8px 48px 72px;align-items:start;}
  .pg-sticky{position:sticky;top:98px;}
  .gmain{position:relative;width:100%;padding-bottom:110%;background:#0e0c0a;overflow:hidden;}
  .gmain img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
  .gmain .ph{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:monospace;font-size:11px;color:#3a3028;text-align:center;}
  .gthumbs{display:flex;gap:8px;margin-top:10px;}
  .gthumbs button{flex:0 0 76px;aspect-ratio:1;background:#0e0c0a;border:1px solid #1f1f1f;overflow:hidden;cursor:pointer;padding:0;}
  .gthumbs button.active{border:2px solid #C4A843;}
  .gthumbs img{width:100%;height:100%;object-fit:cover;display:block;}
  .p-badge{display:inline-block;font-size:9px;letter-spacing:0.18em;font-weight:700;text-transform:uppercase;padding:4px 10px;margin-bottom:14px;}
  .p-title{font-family:'Playfair Display',serif;font-size:30px;color:#f2ede1;font-weight:400;line-height:1.2;margin-bottom:10px;}
  .p-sub{font-size:11px;color:#C4A843;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid #1a1512;}
  .p-price-row{display:flex;gap:12px;align-items:baseline;margin-bottom:14px;}
  .p-price{font-size:28px;color:#f2ede1;font-weight:600;}
  .p-compare{font-size:16px;color:rgba(242,237,225,0.35);text-decoration:line-through;}
  .p-desc{font-size:13px;color:rgba(242,237,225,0.6);font-weight:300;line-height:1.85;margin-bottom:22px;}
  .p-opt-label{font-size:10px;letter-spacing:0.16em;color:rgba(242,237,225,0.5);font-weight:700;text-transform:uppercase;margin-bottom:10px;}
  .p-select{width:100%;padding:13px 16px;background:#111;border:1px solid #2a2218;color:#f2ede1;font-family:'Montserrat',sans-serif;font-size:13px;margin-bottom:18px;outline:none;}
  .p-qty{display:flex;align-items:center;gap:0;margin-bottom:18px;width:fit-content;border:1px solid rgba(242,237,225,0.25);}
  .p-qty button{width:42px;height:44px;background:transparent;border:none;color:#f2ede1;font-size:18px;cursor:pointer;}
  .p-qty input{width:54px;height:44px;background:transparent;border:none;border-left:1px solid rgba(242,237,225,0.2);border-right:1px solid rgba(242,237,225,0.2);color:#f2ede1;text-align:center;font-size:14px;outline:none;-moz-appearance:textfield;}
  .p-qty input::-webkit-outer-spin-button,.p-qty input::-webkit-inner-spin-button{-webkit-appearance:none;}
  .p-atc{width:100%;padding:16px;background:#C4A843;color:#080808;font-size:11px;letter-spacing:0.2em;font-weight:800;text-transform:uppercase;border:none;cursor:pointer;margin-bottom:10px;transition:opacity 0.2s;}
  .p-atc:hover{opacity:0.92;}
  .p-atc[disabled]{background:#2a2a2a;color:rgba(242,237,225,0.4);cursor:not-allowed;}
  .p-trust{display:flex;flex-direction:column;gap:8px;padding:16px 0;border-top:1px solid #1a1512;border-bottom:1px solid #1a1512;margin:6px 0 20px;}
  .p-trust div{display:flex;gap:10px;align-items:center;}
  .p-trust span.i{color:#C4A843;font-size:9px;}
  .p-trust span.t{font-size:11px;color:rgba(242,237,225,0.55);font-weight:300;}
  .acc{border-bottom:1px solid #1a1512;}
  .acc summary{list-style:none;display:flex;justify-content:space-between;align-items:center;padding:16px 0;cursor:pointer;font-size:12px;color:#f2ede1;font-weight:600;letter-spacing:0.06em;}
  .acc summary::-webkit-details-marker{display:none;}
  .acc summary::after{content:'+';color:#C4A843;font-size:18px;}
  .acc[open] summary::after{content:'\2013';}
  .acc .body{padding-bottom:20px;font-size:12px;color:rgba(242,237,225,0.65);font-weight:300;line-height:1.8;}
  .acc .body ul{list-style:none;display:flex;flex-direction:column;gap:9px;}
  .acc .body li{display:flex;gap:10px;}
  .acc .body li::before{content:'\2726';color:#C4A843;flex-shrink:0;}
  .pg-sec{padding:0 48px 72px;max-width:1440px;margin:0 auto;}
  .ymay{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;}
  .pcard-img{position:relative;overflow:hidden;transition:transform 0.4s ease;aspect-ratio:1;margin-bottom:14px;background-size:cover;background-position:center;}
  .pcard:hover .pcard-img{transform:scale(1.02);}
  .hhp-ft{background:#080808;padding:56px 48px 32px;border-top:1px solid #1a1510;}
  .hhp-ft-grid{max-width:1440px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;padding-bottom:40px;border-bottom:1px solid #1a1510;}
  .hhp-ft h5{font-size:10px;letter-spacing:0.16em;color:#f2ede1;text-transform:uppercase;font-weight:700;margin-bottom:16px;}
  .hhp-ft .col a{display:block;font-size:12px;color:rgba(242,237,225,0.4);font-weight:300;margin-bottom:10px;}
  .hhp-ft-logo{height:56px;margin-bottom:14px;display:block;}
  .hhp-ft-bot{max-width:1440px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;padding-top:24px;}
  .hhp-ft-bot p,.hhp-ft-bot span{font-size:10px;color:rgba(242,237,225,0.2);font-weight:300;}
  @media(max-width:1024px){.pg{gap:36px;padding:8px 28px 60px;}.ymay{grid-template-columns:repeat(2,1fr);}.hhp-ft-grid{grid-template-columns:1fr 1fr;}}
  @media(max-width:768px){.hbg{display:flex!important;}.hhp-l,.hhp-r,.hhp-ic{display:none!important;}.hhp-hn{grid-template-columns:auto 1fr auto!important;padding:0 18px!important;height:60px!important;}.hhp-logo img{height:46px!important;}.pg{grid-template-columns:1fr!important;gap:22px!important;padding:8px 18px 52px!important;}.pg-sticky{position:static!important;}.ymay{grid-template-columns:repeat(2,1fr);gap:12px;}.pg-sec{padding:0 18px 56px!important;}}
{%- endstyle -%}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

{%- if settings.logo != blank -%}{%- assign logo_src = settings.logo | image_url: height: 124 -%}{%- else -%}{%- assign logo_src = 'hh-logo.png' | asset_url -%}{%- endif -%}
{%- assign coll = product.collections.first -%}

<div class="hhp">
  <div class="hhp-ann"><div>
    <span>{{ section.settings.announcement_text }} &nbsp;&#10022;&nbsp; {{ section.settings.announcement_text }} &nbsp;&#10022;&nbsp;</span>
  </div></div>

  <nav class="hhp-nav">
    <div class="hhp-hn">
      <button class="hbg" aria-label="Menu" onclick="document.getElementById('hhpMenu').style.cssText='opacity:1;pointer-events:auto'"><span></span><span></span><span></span></button>
      <div class="hhp-l">
        <a class="hhp-link" href="/collections/necklaces">Necklaces</a>
        <a class="hhp-link" href="/collections/rings">Rings</a>
        <a class="hhp-link" href="/collections/bracelets">Bracelets</a>
        <a class="hhp-link" href="/collections/earrings">Earrings</a>
      </div>
      <a class="hhp-logo" href="/"><img src="{{ logo_src }}" alt="{{ shop.name }}" onerror="this.outerHTML='<span>HUMBLE HEARTED</span>'"></a>
      <div style="display:flex;gap:12px;align-items:center;justify-content:flex-end;">
        <div class="hhp-r">
          <a class="hhp-link" href="/collections">Collections</a>
          <a class="hhp-link" style="color:#C4A843;font-weight:700;" href="/collections/all?sort_by=created-descending">New</a>
          <a class="hhp-link" href="/collections/gifts">Gifts</a>
        </div>
        <div class="hhp-ic">
          <a href="/search" aria-label="Search"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path></svg></a>
          <a href="/account" aria-label="Account"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></a>
          <a href="/cart" aria-label="Cart" style="position:relative;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg><span style="position:absolute;top:-7px;right:-7px;background:#8B1818;color:#fff;font-size:9px;width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;">{{ cart.item_count }}</span></a>
        </div>
      </div>
    </div>
  </nav>

  <div class="hhp-crumb">
    <a href="/">Home</a><span>/</span>
    {%- if coll -%}<a href="{{ coll.url }}">{{ coll.title }}</a><span>/</span>{%- endif -%}
    <span style="color:rgba(242,237,225,0.65);">{{ product.title }}</span>
  </div>

  <div class="pg">
    <div class="pg-sticky">
      <div class="gmain" id="hhpMain">
        {%- if product.featured_media -%}
          <img src="{{ product.featured_media | image_url: width: 1000 }}" alt="{{ product.title | escape }}">
        {%- else -%}
          <span class="ph">[ product image ]</span>
        {%- endif -%}
      </div>
      {%- if product.media.size > 1 -%}
        <div class="gthumbs">
          {%- for media in product.media limit: 6 -%}
            <button class="{% if forloop.first %}active{% endif %}" onclick="hhpSwap(this,'{{ media | image_url: width: 1000 }}','{{ product.title | escape }}')"><img src="{{ media | image_url: width: 200 }}" alt=""></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div>
      {%- if product.compare_at_price > product.price -%}
        <span class="p-badge" style="color:#8B1818;background:rgba(139,24,24,0.15);border:1px solid rgba(139,24,24,0.3);">Sale</span>
      {%- elsif product.tags contains 'New' -%}
        <span class="p-badge" style="color:#8B1818;background:rgba(139,24,24,0.15);border:1px solid rgba(139,24,24,0.3);">New In</span>
      {%- endif -%}
      <h1 class="p-title">{{ product.title }}</h1>
      <p class="p-sub">{{ product.type | default: '18k Gold Vermeil' }}</p>

      <div class="p-price-row">
        <span class="p-price" id="hhpPrice">{{ product.price | money }}</span>
        {%- if product.compare_at_price > product.price -%}<span class="p-compare">{{ product.compare_at_price | money }}</span>{%- endif -%}
      </div>

      {%- if product.description != blank -%}
        <div class="p-desc">{{ product.description | strip_html | truncatewords: 60 }}</div>
      {%- endif -%}

      {%- form 'product', product -%}
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <p class="p-opt-label">{{ option.name }}</p>
            <select class="p-select" name="options[{{ option.name | escape }}]" onchange="hhpVariant()">
              {%- for value in option.values -%}<option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>{%- endfor -%}
            </select>
          {%- endfor -%}
        {%- endunless -%}

        <select name="id" id="hhpVariantId" style="display:none;">
          {%- for v in product.variants -%}
            <option value="{{ v.id }}" {% if v == product.selected_or_first_available_variant %}selected{% endif %} {% unless v.available %}disabled{% endunless %} data-price="{{ v.price | money }}">{{ v.title }}</option>
          {%- endfor -%}
        </select>

        <p class="p-opt-label">Quantity</p>
        <div class="p-qty">
          <button type="button" onclick="hhpQty(-1)" aria-label="Decrease">&minus;</button>
          <input type="number" name="quantity" id="hhpQty" value="1" min="1">
          <button type="button" onclick="hhpQty(1)" aria-label="Increase">+</button>
        </div>

        <button type="submit" class="p-atc" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
          {%- if product.selected_or_first_available_variant.available -%}Add to Cart — {{ product.price | money }}{%- else -%}Sold Out{%- endif -%}
        </button>
      {%- endform -%}

      <div class="p-trust">
        <div><span class="i">&#10022;</span><span class="t">Free shipping on orders $75+</span></div>
        <div><span class="i">&#10022;</span><span class="t">2-year manufacturing warranty</span></div>
        <div><span class="i">&#10022;</span><span class="t">60-day hassle-free returns</span></div>
        <div><span class="i">&#10022;</span><span class="t">Gift wrap available at checkout</span></div>
      </div>

      {%- if product.description != blank -%}
        <details class="acc" open><summary>Details &amp; Materials</summary><div class="body">{{ product.description }}</div></details>
      {%- endif -%}
      <details class="acc"><summary>Sustainability</summary><div class="body"><ul>
        <li>Recycled 925 sterling silver base metal</li>
        <li>Water-based, low-VOC lacquer coating</li>
        <li>Carbon-neutral shipping on every order</li>
        <li>100% recycled &amp; recyclable packaging</li>
      </ul></div></details>
      <details class="acc"><summary>Shipping, Returns &amp; Warranty</summary><div class="body"><ul>
        <li>Free standard shipping on orders $75+ (3&ndash;5 business days)</li>
        <li>Expedited 2&ndash;3 days ($12) &middot; Express 1&ndash;2 days ($24)</li>
        <li>60-day hassle-free returns on unworn items</li>
        <li>2-year manufacturing warranty on all pieces</li>
      </ul></div></details>
    </div>
  </div>

  {%- if coll and coll.products.size > 1 -%}
    <section class="pg-sec">
      <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:28px;flex-wrap:wrap;gap:12px;">
        <div>
          <p style="font-size:10px;letter-spacing:0.28em;color:#C4A843;margin-bottom:8px;font-weight:700;text-transform:uppercase;">Complete The Look</p>
          <h2 style="font-family:'Playfair Display',serif;font-size:28px;color:#f2ede1;font-weight:400;">You May Also Like</h2>
        </div>
        <a href="{{ coll.url }}" style="font-size:10px;letter-spacing:0.16em;font-weight:700;color:#C4A843;text-transform:uppercase;border-bottom:1px solid #C4A843;padding-bottom:3px;">View All &rarr;</a>
      </div>
      <div class="ymay">
        {%- assign shown = 0 -%}
        {%- for rel in coll.products -%}
          {%- if rel.id != product.id and shown < 4 -%}
            {%- assign shown = shown | plus: 1 -%}
            <a href="{{ rel.url }}" class="pcard" style="display:block;">
              <div class="pcard-img" style="{% if rel.featured_image %}background-image:url('{{ rel.featured_image | image_url: width: 500 }}');{% else %}background:repeating-linear-gradient(135deg,#120e09 0,#120e09 11px,#1c1710 11px,#1c1710 22px);{% endif %}"></div>
              <p style="font-size:9px;color:#C4A843;letter-spacing:0.12em;margin-bottom:5px;font-weight:700;text-transform:uppercase;">{{ rel.type | default: '18k Gold Vermeil' }}</p>
              <p style="font-family:'Playfair Display',serif;font-size:16px;color:#f2ede1;margin-bottom:6px;line-height:1.3;">{{ rel.title }}</p>
              <div style="display:flex;gap:8px;align-items:center;">
                <span style="font-size:14px;color:#f2ede1;font-weight:600;">{{ rel.price | money }}</span>
                {%- if rel.compare_at_price > rel.price -%}<span style="font-size:12px;color:rgba(242,237,225,0.35);text-decoration:line-through;">{{ rel.compare_at_price | money }}</span>{%- endif -%}
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}

  <footer class="hhp-ft">
    <div class="hhp-ft-grid">
      <div>
        {%- if settings.logo != blank -%}<img class="hhp-ft-logo" src="{{ settings.logo | image_url: height: 112 }}" alt="{{ shop.name }}">{%- else -%}<div class="hhp-ft-logo"><span style="font-family:'Playfair Display',serif;font-size:22px;letter-spacing:0.15em;color:#f2ede1;">HUMBLE HEARTED</span></div>{%- endif -%}
        <p style="font-size:11px;color:rgba(242,237,225,0.35);line-height:1.8;max-width:230px;font-weight:300;">Luxury for the real. Crafted for people with beautiful hearts.</p>
      </div>
      <div class="col"><h5>Shop</h5><a href="/collections/necklaces">Necklaces</a><a href="/collections/rings">Rings</a><a href="/collections/bracelets">Bracelets</a><a href="/collections/earrings">Earrings</a></div>
      <div class="col"><h5>Help</h5><a href="#">FAQs</a><a href="#">Shipping</a><a href="#">Returns</a></div>
      <div class="col"><h5>About</h5><a href="#">Our Story</a><a href="#">Sustainability</a></div>
    </div>
    <div class="hhp-ft-bot">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All Rights Reserved.</p>
      <span>Visa &middot; Mastercard &middot; Amex &middot; Shop Pay &middot; Apple Pay</span>
    </div>
  </footer>
</div>

<div id="hhpMenu" style="position:fixed;inset:0;z-index:999;background:#080808;display:flex;flex-direction:column;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.35s ease;padding:40px 24px;">
  <button onclick="document.getElementById('hhpMenu').style.cssText='opacity:0;pointer-events:none'" style="position:absolute;top:20px;right:20px;background:none;border:none;cursor:pointer;color:#f2ede1;font-size:32px;">&times;</button>
  <a href="/collections/necklaces" style="font-family:'Playfair Display',serif;font-size:26px;color:#f2ede1;margin-bottom:16px;">Necklaces</a>
  <a href="/collections/rings" style="font-family:'Playfair Display',serif;font-size:26px;color:#f2ede1;margin-bottom:16px;">Rings</a>
  <a href="/collections/bracelets" style="font-family:'Playfair Display',serif;font-size:26px;color:#f2ede1;margin-bottom:16px;">Bracelets</a>
  <a href="/collections/earrings" style="font-family:'Playfair Display',serif;font-size:26px;color:#f2ede1;margin-bottom:16px;">Earrings</a>
  <a href="/collections" style="font-size:13px;letter-spacing:0.18em;color:#f2ede1;text-transform:uppercase;font-weight:700;margin-bottom:11px;">Collections</a>
  <a href="/collections/all?sort_by=created-descending" style="font-size:13px;letter-spacing:0.18em;color:#C4A843;text-transform:uppercase;font-weight:700;margin-bottom:11px;">New</a>
  <a href="/collections/gifts" style="font-size:13px;letter-spacing:0.18em;color:#f2ede1;text-transform:uppercase;font-weight:700;">Gifts</a>
</div>

<script>
  function hhpSwap(btn,url,alt){var m=document.getElementById('hhpMain');m.innerHTML='<img src="'+url+'" alt="'+alt+'">';document.querySelectorAll('.gthumbs button').forEach(function(b){b.classList.remove('active');});btn.classList.add('active');}
  function hhpQty(d){var q=document.getElementById('hhpQty');var v=parseInt(q.value||'1',10)+d;if(v<1)v=1;q.value=v;}
  function hhpVariant(){
    var sels=document.querySelectorAll('select[name^="options["]');var chosen=[];sels.forEach(function(s){chosen.push(s.value);});
    var idSel=document.getElementById('hhpVariantId');
    // match by option combination via the hidden id select option text (variant title)
    var want=chosen.join(' / ');
    for(var i=0;i<idSel.options.length;i++){if(idSel.options[i].text===want){idSel.selectedIndex=i;var p=idSel.options[i].getAttribute('data-price');if(p){document.getElementById('hhpPrice').textContent=p;var atc=document.querySelector('.p-atc');if(atc&&!idSel.options[i].disabled){atc.textContent='Add to Cart — '+p;}}break;}}
  }
</script>

