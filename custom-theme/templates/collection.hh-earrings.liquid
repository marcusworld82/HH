{%- comment -%}
  Humble Hearted dark/gold collection template.
  Assign a collection to the "hh-earrings" template to render it with this design.
  Uses layout none so the design renders standalone (no theme header/footer).
{%- endcomment -%}
{% layout none %}<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ collection.title }} &middot; {{ shop.name }}</title>
  <link rel="canonical" href="{{ canonical_url }}">
  {{ content_for_header }}
</head>
<body>
  {% section 'hh-earrings-collection' %}
</body>
</html>
