<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#080808">
  <title>{{ page_title }}</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  {{ content_for_header }}
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    html,body{margin:0;padding:0;border:0;outline:0;background:#080808;overflow-x:hidden;}
  </style>
</head>
<body style="margin:0;padding:0;background:#080808;">
  {% render 'hh-nav' %}
  {{ content_for_layout }}
</body>
</html>