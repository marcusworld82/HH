{%- comment -%}
  Humble Hearted — cart page (dark/gold). Real Shopify cart: line items, qty, remove, checkout.
  Used via templates/cart.json + layout hh-standalone.
{%- endcomment -%}
{%- style -%}
  .hhx *,.hhx *::before,.hhx *::after{margin:0;padding:0;box-sizing:border-box;}
  .hhx{background:#080808;color:#f2ede1;font-family:'Montserrat',sans-serif;overflow-x:hidden;min-height:100vh;display:flex;flex-direction:column;}
  .hhx a{color:inherit;text-decoration:none;}
  .hhx-wrap{flex:1;max-width:1180px;margin:0 auto;width:100%;padding:48px 48px 80px;}
  .hhx-head{text-align:center;margin-bottom:40px;}
  .hhx-eyebrow{font-size:10px;letter-spacing:0.3em;color:#C4A843;font-weight:700;text-transform:uppercase;margin-bottom:12px;}
  .hhx-h1{font-family:'Playfair Display',serif;font-size:44px;color:#f2ede1;font-weight:400;}
  .hhx-grid{display:grid;grid-template-columns:1fr 360px;gap:48px;align-items:start;}
  .hhx-row{display:grid;grid-template-columns:96px 1fr auto;gap:20px;padding:24px 0;border-bottom:1px solid #1a1510;align-items:center;}
  .hhx-img{width:96px;height:96px;background:#0e0c0a;overflow:hidden;}
  .hhx-img img{width:100%;height:100%;object-fit:cover;display:block;}
  .hhx-mat{font-size:9px;color:#C4A843;letter-spacing:0.12em;font-weight:700;text-transform:uppercase;margin-bottom:5px;}
  .hhx-name{font-family:'Playfair Display',serif;font-size:17px;color:#f2ede1;margin-bottom:5px;}
  .hhx-var{font-size:11px;color:rgba(242,237,225,0.45);font-weight:300;margin-bottom:10px;}
  .hhx-qty{display:inline-flex;align-items:center;border:1px solid rgba(242,237,225,0.22);}
  .hhx-qty a{width:34px;height:34px;display:flex;align-items:center;justify-content:center;color:#f2ede1;font-size:16px;}
  .hhx-qty span{min-width:38px;height:34px;display:flex;align-items:center;justify-content:center;font-size:13px;border-left:1px solid rgba(242,237,225,0.18);border-right:1px solid rgba(242,237,225,0.18);}
  .hhx-remove{display:inline-block;margin-left:16px;font-size:10px;letter-spacing:0.1em;color:rgba(242,237,225,0.4);text-transform:uppercase;border-bottom:1px solid rgba(242,237,225,0.2);padding-bottom:1px;}
  .hhx-lineprice{text-align:right;font-size:15px;color:#f2ede1;font-weight:600;white-space:nowrap;}
  .hhx-sum{background:#0d0b08;border:1px solid #1a1510;padding:28px;position:sticky;top:100px;}
  .hhx-sum h3{font-family:'Playfair Display',serif;font-size:20px;color:#f2ede1;font-weight:400;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid #1a1510;}
  .hhx-sumrow{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px;font-size:13px;color:rgba(242,237,225,0.6);font-weight:300;}
  .hhx-total{display:flex;justify-content:space-between;align-items:baseline;margin:18px 0;padding-top:18px;border-top:1px solid #1a1510;}
  .hhx-total .l{font-size:12px;letter-spacing:0.14em;text-transform:uppercase;font-weight:700;color:#f2ede1;}
  .hhx-total .v{font-size:24px;color:#f2ede1;font-weight:600;font-family:'Playfair Display',serif;}
  .hhx-note{font-size:11px;color:rgba(242,237,225,0.35);font-weight:300;margin-bottom:18px;line-height:1.6;}
  .hhx-checkout{width:100%;padding:16px;background:#C4A843;color:#080808;font-size:11px;letter-spacing:0.2em;font-weight:800;text-transform:uppercase;border:none;cursor:pointer;margin-bottom:10px;}
  .hhx-update{width:100%;padding:13px;background:transparent;border:1px solid rgba(242,237,225,0.25);color:#f2ede1;font-size:10px;letter-spacing:0.18em;font-weight:700;text-transform:uppercase;cursor:pointer;}
  .hhx-cont{display:block;text-align:center;margin-top:16px;font-size:11px;letter-spacing:0.14em;color:#C4A843;text-transform:uppercase;font-weight:700;}
  .hhx-empty{text-align:center;padding:60px 20px;}
  .hhx-empty p{font-size:15px;color:rgba(242,237,225,0.5);font-weight:300;margin-bottom:28px;}
  .hhx-btn{display:inline-block;padding:15px 44px;background:#C4A843;color:#080808;font-size:11px;letter-spacing:0.2em;font-weight:800;text-transform:uppercase;}
  .hhx-ft{background:#080808;padding:48px 48px 28px;border-top:1px solid #1a1510;}
  .hhx-ft-grid{max-width:1440px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:36px;padding-bottom:32px;border-bottom:1px solid #1a1510;}
  .hhx-ft h5{font-size:10px;letter-spacing:0.16em;color:#f2ede1;text-transform:uppercase;font-weight:700;margin-bottom:14px;}
  .hhx-ft .col a{display:block;font-size:12px;color:rgba(242,237,225,0.4);font-weight:300;margin-bottom:9px;}
  .hhx-ft-logo{height:52px;margin-bottom:12px;display:block;}
  .hhx-ft-bot{max-width:1440px;margin:0 auto;display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;padding-top:22px;}
  .hhx-ft-bot p,.hhx-ft-bot span{font-size:10px;color:rgba(242,237,225,0.2);font-weight:300;}
  @media(max-width:768px){.hhx-wrap{padding:32px 18px 60px;}.hhx-h1{font-size:34px;}.hhx-grid{grid-template-columns:1fr;gap:28px;}.hhx-sum{position:static;}.hhx-row{grid-template-columns:72px 1fr;gap:14px;}.hhx-img{width:72px;height:72px;}.hhx-lineprice{grid-column:2;text-align:left;margin-top:8px;}.hhx-ft-grid{grid-template-columns:1fr 1fr;}}
{%- endstyle -%}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<div class="hhx">
  {% render 'hh-nav' %}

  <div class="hhx-wrap">
    <div class="hhx-head">
      <p class="hhx-eyebrow">Your Bag</p>
      <h1 class="hhx-h1">Shopping Bag</h1>
    </div>

    {%- if cart.item_count == 0 -%}
      <div class="hhx-empty">
        <p>Your bag is empty.</p>
        <a class="hhx-btn" href="/collections/all">Start Shopping</a>
      </div>
    {%- else -%}
      <form action="{{ routes.cart_url }}" method="post" id="cart" class="hhx-grid">
        <div>
          {%- for item in cart.items -%}
            <div class="hhx-row">
              <a href="{{ item.url }}" class="hhx-img">{%- if item.image -%}<img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}">{%- endif -%}</a>
              <div>
                <p class="hhx-mat">{{ item.product.type | default: '18k Gold Vermeil' }}</p>
                <a href="{{ item.url }}"><p class="hhx-name">{{ item.product.title }}</p></a>
                {%- unless item.variant.title contains 'Default' -%}<p class="hhx-var">{{ item.variant.title }}</p>{%- endunless -%}
                <div>
                  <span class="hhx-qty">
                    <a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}" aria-label="Decrease">&minus;</a>
                    <span>{{ item.quantity }}</span>
                    <a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}" aria-label="Increase">+</a>
                  </span>
                  <a class="hhx-remove" href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0">Remove</a>
                </div>
              </div>
              <div class="hhx-lineprice">{{ item.final_line_price | money }}</div>
            </div>
          {%- endfor -%}
        </div>

        <div class="hhx-sum">
          <h3>Order Summary</h3>
          <div class="hhx-sumrow"><span>Subtotal</span><span style="color:#f2ede1;font-weight:600;">{{ cart.total_price | money }}</span></div>
          <div class="hhx-sumrow"><span>Shipping</span><span>Calculated at checkout</span></div>
          <div class="hhx-total"><span class="l">Total</span><span class="v">{{ cart.total_price | money }}</span></div>
          <p class="hhx-note">Taxes and shipping calculated at checkout. Free standard shipping on orders $75+.</p>
          <button type="submit" name="checkout" class="hhx-checkout">Checkout</button>
          <button type="submit" name="update" class="hhx-update">Update Bag</button>
          <a class="hhx-cont" href="/collections/all">Continue Shopping &rarr;</a>
        </div>
      </form>
    {%- endif -%}
  </div>

  <footer class="hhx-ft">
    <div class="hhx-ft-grid">
      <div>{%- if settings.logo != blank -%}<img class="hhx-ft-logo" src="{{ settings.logo | image_url: height: 104 }}" alt="{{ shop.name }}">{%- else -%}<div class="hhx-ft-logo"><span style="font-family:'Playfair Display',serif;font-size:22px;letter-spacing:0.15em;color:#f2ede1;">HUMBLE HEARTED</span></div>{%- endif -%}<p style="font-size:11px;color:rgba(242,237,225,0.35);line-height:1.8;max-width:230px;font-weight:300;">Luxury for the real. Crafted for people with beautiful hearts.</p></div>
      <div class="col"><h5>Shop</h5><a href="/collections/necklaces">Necklaces</a><a href="/collections/rings">Rings</a><a href="/collections/bracelets">Bracelets</a><a href="/collections/earrings">Earrings</a></div>
      <div class="col"><h5>Help</h5><a href="#">FAQs</a><a href="#">Shipping</a><a href="#">Returns</a></div>
      <div class="col"><h5>About</h5><a href="#">Our Story</a><a href="#">Sustainability</a></div>
    </div>
    <div class="hhx-ft-bot"><p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All Rights Reserved.</p><span>Visa &middot; Mastercard &middot; Amex &middot; Shop Pay &middot; Apple Pay</span></div>
  </footer>
</div>

{% schema %}
{
  "name": "HH Cart",
  "settings": [
    { "type": "header", "content": "Announcement Bar" },
    { "type": "text", "id": "announcement_text", "label": "Announcement text", "default": "Free Shipping On Orders $75+ ✦ Sign Up For 10% Off ✦ 60-Day Returns ✦ 2-Year Warranty" }
  ]
}
{% endschema %}
