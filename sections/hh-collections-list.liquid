{%- comment -%}
  Humble Hearted — Collections Landing Page
  Matches the dark/gold design of all HH collection pages.
  Assign template "list-collections.hh" to the /collections URL in Shopify.
{%- endcomment -%}

{%- style -%}
  .hhcl *,.hhcl *::before,.hhcl *::after{margin:0;padding:0;box-sizing:border-box;}
  .hhcl{background:#080808;color:#f2ede1;font-family:'Montserrat',sans-serif;overflow-x:hidden;}
  .hhcl a{color:inherit;text-decoration:none;}
  .hhcl-hero{height:280px;position:relative;overflow:hidden;background:repeating-linear-gradient(45deg,#100a14 0,#100a14 18px,#180f1e 18px,#180f1e 36px);}
  .hhcl-hero-inner{position:absolute;inset:0;background:rgba(8,8,8,0.5);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:24px;}
  .hhcl-hero-eyebrow{font-size:10px;letter-spacing:0.3em;color:#C4A843;margin-bottom:12px;font-weight:700;text-transform:uppercase;}
  .hhcl-hero-title{font-family:'Playfair Display',serif;font-size:56px;color:#f2ede1;font-weight:400;margin-bottom:12px;}
  .hhcl-hero-sub{font-size:12px;color:rgba(242,237,225,0.45);font-weight:300;letter-spacing:0.08em;}
  .hhcl-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:0;max-width:1440px;margin:48px auto;padding:0 48px;gap:20px;}
  .hhcl-cat{position:relative;overflow:hidden;display:block;cursor:pointer;aspect-ratio:4/5;background:#111;}
  .hhcl-cat-bg{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform 0.6s cubic-bezier(0.25,0.46,0.45,0.94);}
  .hhcl-cat:hover .hhcl-cat-bg{transform:scale(1.06);}
  .hhcl-cat-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(8,8,8,0.82) 0%,rgba(8,8,8,0.18) 55%,rgba(8,8,8,0) 100%);}
  .hhcl-cat-body{position:absolute;bottom:0;left:0;right:0;padding:28px 28px 32px;}
  .hhcl-cat-eyebrow{font-size:9px;letter-spacing:0.25em;color:#C4A843;text-transform:uppercase;font-weight:700;margin-bottom:8px;}
  .hhcl-cat-title{font-family:'Playfair Display',serif;font-size:36px;color:#f2ede1;font-weight:400;margin-bottom:14px;line-height:1.15;}
  .hhcl-cat-cta{display:inline-flex;align-items:center;gap:8px;font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#C4A843;position:relative;}
  .hhcl-cat-cta::after{content:'';position:absolute;bottom:-3px;left:0;width:0;height:1px;background:#C4A843;transition:width 0.35s ease;}
  .hhcl-cat:hover .hhcl-cat-cta::after{width:100%;}
  .hhcl-cat-cta svg{transition:transform 0.3s ease;}
  .hhcl-cat:hover .hhcl-cat-cta svg{transform:translateX(4px);}
  .hhcl-cat-count{position:absolute;top:18px;right:18px;font-size:9px;font-weight:700;letter-spacing:0.14em;color:#f2ede1;background:rgba(8,8,8,0.6);border:1px solid rgba(196,168,67,0.3);padding:5px 10px;text-transform:uppercase;}
  .hhcl-promise{border-top:1px solid #1a1510;border-bottom:1px solid #1a1510;padding:28px 48px;margin-bottom:0;}
  .hhcl-promise-inner{max-width:1440px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}
  .hhcl-promise-item{display:flex;flex-direction:column;align-items:center;text-align:center;gap:8px;}
  .hhcl-promise-icon{color:#C4A843;}
  .hhcl-promise-label{font-size:10px;letter-spacing:0.16em;color:#f2ede1;text-transform:uppercase;font-weight:700;}
  .hhcl-promise-sub{font-size:11px;color:rgba(242,237,225,0.4);font-weight:300;}
  .hhcl-ft{background:#080808;padding:48px 48px 28px;border-top:1px solid #1a1510;}
  .hhcl-ft-inner{max-width:1440px;margin:0 auto;}
  .hhcl-ft-cols{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:36px;margin-bottom:36px;padding-bottom:36px;border-bottom:1px solid #1a1510;}
  .hhcl-ft-tag{font-size:11px;color:rgba(242,237,225,0.35);line-height:1.8;max-width:220px;font-weight:300;}
  .hhcl-ft-h{font-size:10px;letter-spacing:0.16em;color:#f2ede1;text-transform:uppercase;font-weight:700;margin-bottom:14px;}
  .hhcl-ft-list{display:flex;flex-direction:column;gap:9px;}
  .hhcl-ft-list a{font-size:12px;color:rgba(242,237,225,0.4);font-weight:300;}
  .hhcl-ft-logo{height:52px;width:auto;display:block;margin-bottom:12px;}
  .hhcl-ft-logo span{font-family:'Playfair Display',serif;font-size:22px;color:#f2ede1;letter-spacing:0.15em;}
  .hhcl-ft-bottom{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;}
  .hhcl-ft-copy{font-size:11px;color:rgba(242,237,225,0.2);font-weight:300;}
  .hhcl-ft-pay{font-size:10px;color:rgba(242,237,225,0.2);}
  @media(max-width:1024px){.hhcl-grid{padding:0 28px;gap:16px;}.hhcl-ft-cols{grid-template-columns:repeat(3,1fr);}}
  @media(max-width:768px){
    .hhcl-hero-title{font-size:40px;}
    .hhcl-grid{grid-template-columns:1fr;padding:0 18px;gap:14px;margin:32px auto;}
    .hhcl-cat{aspect-ratio:3/4;}
    .hhcl-cat-title{font-size:28px;}
    .hhcl-promise-inner{grid-template-columns:repeat(2,1fr);}
    .hhcl-promise{padding:24px 18px;}
    .hhcl-ft-cols{grid-template-columns:repeat(2,1fr);}
    .hhcl-ft{padding:36px 18px 24px;}
  }
{%- endstyle -%}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

{%- assign cat_handles = 'necklaces,rings,bracelets,earrings' | split: ',' -%}
{%- assign cat_labels = 'Necklaces,Rings,Bracelets,Earrings' | split: ',' -%}
{%- assign cat_eyebrows = 'Layering Pieces,Stack & Shine,Wrist Candy,Ear Art' | split: ',' -%}
{%- assign cat_fallbacks = 'repeating-linear-gradient(135deg,#130f0a 0,#130f0a 11px,#1c1610 11px,#1c1610 22px)|repeating-linear-gradient(45deg,#0a0d12 0,#0a0d12 11px,#0f121a 11px,#0f121a 22px)|repeating-linear-gradient(45deg,#110e07 0,#110e07 11px,#19140a 11px,#19140a 22px)|repeating-linear-gradient(135deg,#0f0a12 0,#0f0a12 11px,#160f1a 11px,#160f1a 22px)' | split: '|' -%}

<div class="hhcl">
  {% render 'hh-nav' %}

  <section class="hhcl-hero" style="{% if section.settings.hero_image != blank %}background-image:url('{{ section.settings.hero_image | image_url: width: 1600 }}');background-size:cover;background-position:center;{% endif %}">
    <div class="hhcl-hero-inner">
      <p class="hhcl-hero-eyebrow">{{ section.settings.hero_eyebrow | default: 'Shop By Category' }}</p>
      <h1 class="hhcl-hero-title">{{ section.settings.hero_title | default: 'Collections' }}</h1>
      <p class="hhcl-hero-sub">{{ section.settings.hero_subtitle | default: 'Crafted for people with beautiful hearts' }}</p>
    </div>
  </section>

  <div class="hhcl-grid">
    {%- for i in (0..3) -%}
      {%- assign handle = cat_handles[i] -%}
      {%- assign label = cat_labels[i] -%}
      {%- assign eyebrow = cat_eyebrows[i] -%}
      {%- assign fallback_bg = cat_fallbacks[i] -%}
      {%- assign col = collections[handle] -%}
      <a class="hhcl-cat" href="/collections/{{ handle }}">
        <div class="hhcl-cat-bg" style="{% if col.image %}background-image:url('{{ col.image | image_url: width: 900 }}');{% else %}background:{{ fallback_bg }};{% endif %}"></div>
        <div class="hhcl-cat-overlay"></div>
        {%- if col.products_count > 0 -%}<span class="hhcl-cat-count">{{ col.products_count }} Pieces</span>{%- endif -%}
        <div class="hhcl-cat-body">
          <p class="hhcl-cat-eyebrow">{{ eyebrow }}</p>
          <h2 class="hhcl-cat-title">{{ label }}</h2>
          <span class="hhcl-cat-cta">Shop Now <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></span>
        </div>
      </a>
    {%- endfor -%}
  </div>

  <div class="hhcl-promise">
    <div class="hhcl-promise-inner">
      <div class="hhcl-promise-item"><svg class="hhcl-promise-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg><span class="hhcl-promise-label">Free Shipping</span><span class="hhcl-promise-sub">On orders $75+</span></div>
      <div class="hhcl-promise-item"><svg class="hhcl-promise-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span class="hhcl-promise-label">Quality Crafted</span><span class="hhcl-promise-sub">18k Gold Vermeil</span></div>
      <div class="hhcl-promise-item"><svg class="hhcl-promise-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg><span class="hhcl-promise-label">Easy Returns</span><span class="hhcl-promise-sub">60-day policy</span></div>
      <div class="hhcl-promise-item"><svg class="hhcl-promise-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg><span class="hhcl-promise-label">10% Off</span><span class="hhcl-promise-sub">Sign up to save</span></div>
    </div>
  </div>

  <footer class="hhcl-ft">
    <div class="hhcl-ft-inner">
      <div class="hhcl-ft-cols">
        <div>{%- if settings.logo != blank -%}<img class="hhcl-ft-logo" src="{{ settings.logo | image_url: height: 104 }}" alt="{{ shop.name }}">{%- else -%}<div class="hhcl-ft-logo"><span>HH</span></div>{%- endif -%}<p class="hhcl-ft-tag">Luxury for the real. Crafted for people with beautiful hearts.</p></div>
        <div><h5 class="hhcl-ft-h">Shop</h5><div class="hhcl-ft-list"><a href="/collections/necklaces">Necklaces</a><a href="/collections/rings">Rings</a><a href="/collections/bracelets">Bracelets</a><a href="/collections/earrings">Earrings</a></div></div>
        <div><h5 class="hhcl-ft-h">Help</h5><div class="hhcl-ft-list"><a href="/pages/faqs">FAQs</a><a href="/pages/shipping">Shipping</a><a href="/pages/returns">Returns</a></div></div>
        <div><h5 class="hhcl-ft-h">About</h5><div class="hhcl-ft-list"><a href="/pages/our-story">Our Story</a><a href="/pages/sustainability">Sustainability</a></div></div>
      </div>
      <div class="hhcl-ft-bottom"><p class="hhcl-ft-copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.</p><span class="hhcl-ft-pay">Visa &middot; Mastercard &middot; Shop Pay &middot; Apple Pay</span></div>
    </div>
  </footer>

</div>

{% schema %}
{
  "name": "HH Collections Landing",
  "settings": [
    { "type": "header", "content": "Announcement Bar" },
    { "type": "text", "id": "announcement_text", "label": "Announcement text", "default": "Free Shipping On Orders $75+ ✦ Sign Up For 10% Off ✦ New: Summer Heart Collection ✦ 60-Day Returns" },
    { "type": "header", "content": "Hero Banner" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero background image", "info": "Optional — falls back to dark stripe pattern." },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow text", "default": "Shop By Category" },
    { "type": "text", "id": "hero_title", "label": "Hero title", "default": "Collections" },
    { "type": "text", "id": "hero_subtitle", "label": "Hero subtitle", "default": "Crafted for people with beautiful hearts" }
  ],
  "presets": [{ "name": "HH Collections Landing" }]
}
{% endschema %}
