<script>
  function hhMenu(open){var m=document.getElementById('hhMobileMenu');m.style.opacity=open?'1':'0';m.style.pointerEvents=open?'auto':'none';}
  function hhScroll(dir){var r=document.getElementById('hhBsRow');if(r){r.scrollBy({left:dir*(r.clientWidth/2),behavior:'smooth'});}}
  document.addEventListener('keydown',function(e){if(e.key==='Escape')hhMenu(false);});
</script>

{% schema %}
{
  "name": "HH Home",
  "settings": [
    { "type": "header", "content": "Announcement Bar" },
    { "type": "text", "id": "announcement_text", "label": "Announcement text", "default": "Free Shipping On Orders $75+ ✦ Sign Up For 10% Off ✦ New: Summer Heart Collection ✦ 60-Day Returns" },

    { "type": "header", "content": "Navigation Links" },
    { "type": "text", "id": "nav1_label", "label": "Nav link 1 label", "default": "Necklaces" },
