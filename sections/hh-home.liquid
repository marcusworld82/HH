    {%- for i in (1..4) -%}
      {%- capture ik -%}cat{{ i }}_image{%- endcapture -%}{%- capture tk -%}cat{{ i }}_title{%- endcapture -%}{%- capture lk -%}cat{{ i }}_link{%- endcapture -%}
      {%- assign cimg = section.settings[ik] -%}
      <a class="hh-cat-card" href="{{ section.settings[lk] | default: '/collections/all' }}" style="position:relative;aspect-ratio:2/3;overflow:hidden;cursor:pointer;display:block;text-decoration:none;{% if cimg != blank %}background-image:url('{{ cimg | image_url: width: 600 }}');background-size:cover;background-position:center;{% else %}background:{{ cat_bg[forloop.index0] }};{% endif %}">
        <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(8,8,8,0.88) 0%,rgba(8,8,8,0.08) 55%);display:flex;flex-direction:column;justify-content:flex-end;padding:22px;">
          <p style="font-family:'Playfair Display',serif;font-size:22px;color:#f2ede1;margin-bottom:7px;position:relative;z-index:1;line-height:1.1;">{{ section.settings[tk] }}</p>
