  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { background: #080808; color: #f2ede1; font-family: 'Montserrat', sans-serif; overflow-x: hidden; }
    a { transition: color 0.2s ease, opacity 0.2s ease; }
    @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
    .hide-scroll { scrollbar-width: none; -ms-overflow-style: none; }
    .hide-scroll::-webkit-scrollbar { display: none; }
    .hh-hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 8px; }
    .hh-hamburger span { display: block; width: 22px; height: 2px; background: #f2ede1; border-radius: 1px; }

    /* Shop-the-look hover cross-fade */
    .hh-look-card .layer { position: absolute; inset: 0; transition: opacity 0.55s ease; }
    .hh-look-card .layer-hover, .hh-look-card .pt-hover, .hh-look-card .newview { opacity: 0; }
    .hh-look-card:hover .layer-base, .hh-look-card.flip .layer-base,
    .hh-look-card:hover .pt-base, .hh-look-card.flip .pt-base { opacity: 0; }
    .hh-look-card:hover .layer-hover, .hh-look-card.flip .layer-hover,
    .hh-look-card:hover .pt-hover, .hh-look-card.flip .pt-hover,
    .hh-look-card:hover .newview, .hh-look-card.flip .newview { opacity: 1; }

    /* Product / quick-add hover */
    .hh-bs-card .qa { opacity: 0; transition: opacity 0.3s ease; }
    .hh-bs-card:hover .qa { opacity: 1; }
    .hh-bs-card .hh-bs-img { transition: transform 0.4s ease; }
    .hh-bs-card:hover .hh-bs-img { transform: scale(1.02); }
    .hh-products-row { display: flex; gap: 28px; overflow-x: auto; scroll-snap-type: x mandatory; }
    .hh-bs-card { flex: 0 0 calc((100% - 84px) / 4); scroll-snap-align: start; cursor: pointer; }

    .hh-cat-card:hover { opacity: 0.92; }
    .hh-feat-panel:hover { opacity: 0.95; }

    @media (max-width: 1024px) {
      .hh-nav-inner { padding: 0 28px !important; }
      .hh-nav-left { gap: 18px !important; }
      .hh-hero { height: 580px !important; }
      .hh-hero-h1 { font-size: 58px !important; }
      .hh-cat-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .hh-brand-grid { padding: 72px 28px !important; gap: 48px !important; }
      .hh-bs-card { flex-basis: calc((100% - 28px) / 2); }
      .hh-footer-grid { grid-template-columns: 1fr 1fr 1fr !important; gap: 32px !important; }
      .hh-footer-logo-col { grid-column: 1 / -1 !important; }
    }
    @media (max-width: 768px) {
      .hh-nav-inner { grid-template-columns: auto 1fr auto !important; padding: 0 20px !important; height: 60px !important; }
      .hh-nav-left, .hh-nav-right-links, .hh-nav-divider-text { display: none !important; }
      .hh-hamburger { display: flex !important; }
      .hh-nav-logo img { height: 46px !important; }
      .hh-hero { grid-template-columns: 1fr !important; height: 540px !important; }
      .hh-hero-right-panel { display: none !important; }
      .hh-hero-h1 { font-size: 40px !important; line-height: 1.05 !important; }
      .hh-look-grid { grid-template-columns: 1fr !important; }
      .hh-look-card { height: 340px !important; }
      .hh-brand-grid { grid-template-columns: 1fr !important; gap: 28px !important; padding: 56px 24px !important; }
      .hh-brand-h2 { font-size: 34px !important; }
      .hh-cat-grid { grid-template-columns: 1fr 1fr !important; gap: 10px !important; }
      .hh-feat-grid { grid-template-columns: 1fr !important; height: auto !important; }
      .hh-feat-panel { height: 340px !important; }
      .hh-bs-card { flex-basis: calc((100% - 14px) / 2); }
      .hh-perks-grid { grid-template-columns: 1fr !important; gap: 0 !important; }
      .hh-perks-mid { border-left: none !important; border-right: none !important; border-top: 1px solid rgba(8,8,8,0.15) !important; border-bottom: 1px solid rgba(8,8,8,0.15) !important; padding: 32px 0 !important; }
      .hh-email-h2 { font-size: 38px !important; }
      .hh-email-row { flex-direction: column !important; }
      .hh-email-input { border-right: 1px solid #2a2218 !important; border-bottom: none; }
      .hh-email-btn { width: 100% !important; }
      .hh-footer-grid { grid-template-columns: 1fr 1fr !important; gap: 28px !important; }
      .hh-footer-logo-col { grid-column: 1 / -1 !important; }
      .hh-footer-bottom { flex-direction: column !important; gap: 10px !important; text-align: center !important; }
    }
  </style>

