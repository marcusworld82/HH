      </div>
      <div style="display:flex;gap:8px;align-items:center;">
        <a href="{{ section.settings.bs_view_all_link | default: '/collections/all' }}" style="font-size:10px;letter-spacing:0.18em;font-weight:700;color:rgba(242,237,225,0.4);text-decoration:none;text-transform:uppercase;margin-right:12px;">View All &rarr;</a>
        <button onclick="hhScroll(-1)" style="width:44px;height:44px;background:transparent;border:1px solid #2a2a2a;color:#f2ede1;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;">&larr;</button>
        <button onclick="hhScroll(1)" style="width:44px;height:44px;background:transparent;border:1px solid #2a2a2a;color:#f2ede1;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;">&rarr;</button>
      </div>
    </div>
    <div class="hh-products-row hide-scroll" id="hhBsRow">
      {%- if section.settings.bs_collection != blank -%}{%- assign bs = section.settings.bs_collection.products -%}{%- else -%}{%- assign bs = collections.earrings.products -%}{%- endif -%}
      {%- assign bs_bg = 'repeating-linear-gradient(135deg,#111 0px,#111 11px,#171717 11px,#171717 22px)|repeating-linear-gradient(45deg,#0e0e0e 0px,#0e0e0e 11px,#141414 11px,#141414 22px)|repeating-linear-gradient(135deg,#121008 0px,#121008 11px,#181410 11px,#181410 22px)|repeating-linear-gradient(45deg,#0e1014 0px,#0e1014 11px,#12151a 11px,#12151a 22px)' | split: '|' -%}
      {%- if bs.size > 0 -%}
        {%- for product in bs limit: 8 -%}
          {%- assign bi = forloop.index0 | modulo: 4 -%}
          <a class="hh-bs-card" href="{{ product.url }}" style="text-decoration:none;">
            <div class="hh-bs-img" style="aspect-ratio:1;margin-bottom:16px;position:relative;overflow:hidden;{% if product.featured_image %}background-image:url('{{ product.featured_image | image_url: width: 600 }}');background-size:cover;background-position:center;{% else %}background:{{ bs_bg[bi] }};{% endif %}">
              {%- if product.compare_at_price > product.price -%}<div style="position:absolute;top:10px;left:10px;background:#8B1818;color:white;font-size:9px;font-weight:700;padding:4px 8px;letter-spacing:0.1em;text-transform:uppercase;">Sale</div>{%- endif -%}
              <div class="qa" style="position:absolute;bottom:0;left:0;right:0;background:#080808;color:#C4A843;font-size:9px;font-weight:700;letter-spacing:0.16em;padding:12px;text-align:center;text-transform:uppercase;border-top:1px solid #1f1f1f;">+ Quick Add</div>
            </div>
            <p style="font-size:9px;color:#C4A843;letter-spacing:0.12em;margin-bottom:5px;font-weight:700;text-transform:uppercase;">{{ product.type | default: '18k Gold Vermeil' }}</p>
            <h4 style="font-family:'Playfair Display',serif;font-size:16px;color:#f2ede1;margin-bottom:8px;line-height:1.3;font-weight:400;">{{ product.title }}</h4>
            <div style="margin-bottom:7px;"><span style="color:#C4A843;font-size:12px;letter-spacing:1px;">&#9733;&#9733;&#9733;&#9733;&#9733;</span></div>
            <div style="display:flex;gap:10px;align-items:center;">
              <span style="font-size:15px;color:#f2ede1;font-weight:600;">{{ product.price | money_without_trailing_zeros }}</span>
              {%- if product.compare_at_price > product.price -%}<span style="font-size:13px;color:rgba(242,237,225,0.35);text-decoration:line-through;">{{ product.compare_at_price | money_without_trailing_zeros }}</span>{%- endif -%}
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- assign ph_names = 'Heart Pendant Necklace|Layered Chain Set|Stacked Ring Set|Gold Hoop Earrings|Heart Charm Bracelet|Pearl Drop Earrings' | split: '|' -%}
        {%- assign ph_price = '$89|$129|$95|$65|$145|$75' | split: '|' -%}
        {%- for i in (0..5) -%}
          {%- assign bi = i | modulo: 4 -%}
          <a class="hh-bs-card" href="{{ section.settings.bs_view_all_link | default: '/collections/all' }}" style="text-decoration:none;">
            <div class="hh-bs-img" style="aspect-ratio:1;margin-bottom:16px;position:relative;overflow:hidden;background:{{ bs_bg[bi] }};">
              <div class="qa" style="position:absolute;bottom:0;left:0;right:0;background:#080808;color:#C4A843;font-size:9px;font-weight:700;letter-spacing:0.16em;padding:12px;text-align:center;text-transform:uppercase;border-top:1px solid #1f1f1f;">+ Quick Add</div>
            </div>
            <p style="font-size:9px;color:#C4A843;letter-spacing:0.12em;margin-bottom:5px;font-weight:700;text-transform:uppercase;">18k Gold Vermeil</p>
            <h4 style="font-family:'Playfair Display',serif;font-size:16px;color:#f2ede1;margin-bottom:8px;line-height:1.3;font-weight:400;">{{ ph_names[i] }}</h4>
            <div style="margin-bottom:7px;"><span style="color:#C4A843;font-size:12px;letter-spacing:1px;">&#9733;&#9733;&#9733;&#9733;&#9733;</span></div>
            <div style="display:flex;gap:10px;align-items:center;"><span style="font-size:15px;color:#f2ede1;font-weight:600;">{{ ph_price[i] }}</span></div>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

