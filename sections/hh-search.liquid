{%- comment -%}
  Humble Hearted — search page (dark/gold). Real Shopify search results.
  Used via templates/search.json + layout hh-standalone.
{%- endcomment -%}
{%- style -%}
  .hhs *,.hhs *::before,.hhs *::after{margin:0;padding:0;box-sizing:border-box;}
  .hhs{background:#080808;color:#f2ede1;font-family:'Montserrat',sans-serif;overflow-x:hidden;min-height:100vh;display:flex;flex-direction:column;}
  .hhs a{color:inherit;text-decoration:none;}
  .hhs-wrap{flex:1;max-width:1440px;margin:0 auto;width:100%;padding:56px 48px 80px;}
  .hhs-head{text-align:center;margin-bottom:36px;}
  .hhs-eyebrow{font-size:10px;letter-spacing:0.3em;color:#C4A843;font-weight:700;text-transform:uppercase;margin-bottom:12px;}
  .hhs-h1{font-family:'Playfair Display',serif;font-size:44px;color:#f2ede1;font-weight:400;}
  .hhs-form{max-width:620px;margin:0 auto 18px;display:flex;border-bottom:2px solid #C4A843;}
  .hhs-form input{flex:1;background:none;border:none;font-family:'Playfair Display',serif;font-size:22px;color:#f2ede1;outline:none;padding:10px 4px;}
  .hhs-form input::placeholder{color:rgba(242,237,225,0.3);}
  .hhs-form button{background:none;border:none;cursor:pointer;color:#C4A843;font-size:20px;padding:0 6px;}
  .hhs-tags{display:flex;gap:9px;flex-wrap:wrap;justify-content:center;margin-bottom:44px;}
  .hhs-tags a{padding:7px 13px;border:1px solid #2a2218;color:rgba(242,237,225,0.6);font-size:11px;font-weight:300;}
  .hhs-count{font-size:11px;letter-spacing:0.12em;color:rgba(242,237,225,0.45);text-transform:uppercase;font-weight:600;margin-bottom:24px;text-align:center;}
  .hhs-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:28px;}
  .hhs-card{display:block;}
  .hhs-card-img{position:relative;overflow:hidden;transition:transform 0.4s ease;aspect-ratio:1;margin-bottom:14px;background-size:cover;background-position:center;}
  .hhs-card:hover .hhs-card-img{transform:scale(1.02);}
  .hhs-mat{font-size:9px;color:#C4A843;letter-spacing:0.12em;font-weight:700;text-transform:uppercase;margin-bottom:5px;}
  .hhs-name{font-family:'Playfair Display',serif;font-size:16px;color:#f2ede1;margin-bottom:6px;line-height:1.3;}
  .hhs-price{font-size:14px;color:#f2ede1;font-weight:600;}
  .hhs-none{text-align:center;padding:50px 20px;}
  .hhs-none p{font-size:15px;color:rgba(242,237,225,0.5);font-weight:300;margin-bottom:24px;}
  .hhs-btn{display:inline-block;padding:14px 40px;background:#C4A843;color:#080808;font-size:11px;letter-spacing:0.2em;font-weight:800;text-transform:uppercase;}
  .hhs-ft{background:#080808;padding:48px 48px 28px;border-top:1px solid #1a1510;}
  .hhs-ft-grid{max-width:1440px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:36px;padding-bottom:32px;border-bottom:1px solid #1a1510;}
  .hhs-ft h5{font-size:10px;letter-spacing:0.16em;color:#f2ede1;text-transform:uppercase;font-weight:700;margin-bottom:14px;}
  .hhs-ft .col a{display:block;font-size:12px;color:rgba(242,237,225,0.4);font-weight:300;margin-bottom:9px;}
  .hhs-ft-logo{height:52px;margin-bottom:12px;display:block;}
  .hhs-ft-bot{max-width:1440px;margin:0 auto;display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;padding-top:22px;}
  .hhs-ft-bot p,.hhs-ft-bot span{font-size:10px;color:rgba(242,237,225,0.2);font-weight:300;}
  @media(max-width:1024px){.hhs-grid{grid-template-columns:repeat(3,1fr);}.hhs-ft-grid{grid-template-columns:1fr 1fr;}}
  @media(max-width:768px){.hhs-wrap{padding:36px 18px 60px;}.hhs-h1{font-size:32px;}.hhs-form input{font-size:18px;}.hhs-grid{grid-template-columns:1fr 1fr;gap:14px;}}
{%- endstyle -%}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<div class="hhs">
  {% render 'hh-nav' %}

  <div class="hhs-wrap">
    <div class="hhs-head">
      <p class="hhs-eyebrow">{{ section.settings.hero_eyebrow | default: 'Search' }}</p>
      <h1 class="hhs-h1">{{ section.settings.hero_heading | default: 'Find Your Piece' }}</h1>
    </div>
    <form class="hhs-form" action="{{ routes.search_url }}" method="get" role="search">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search jewelry..." autofocus>
      <button type="submit" aria-label="Search">&rarr;</button>
    </form>
    <div class="hhs-tags">
      <a href="{{ routes.search_url }}?q=gold">Gold</a>
      <a href="{{ routes.search_url }}?q=necklace">Necklaces</a>
      <a href="{{ routes.search_url }}?q=hoop">Hoops</a>
      <a href="{{ routes.search_url }}?q=pearl">Pearl</a>
      <a href="{{ routes.search_url }}?q=heart">Heart</a>
      <a href="{{ routes.search_url }}?q=stud">Studs</a>
    </div>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <p class="hhs-count">{{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %} for &ldquo;{{ search.terms }}&rdquo;</p>
        <div class="hhs-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              <a href="{{ item.url }}" class="hhs-card">
                <div class="hhs-card-img" style="{% if item.featured_image %}background-image:url('{{ item.featured_image | image_url: width: 500 }}');{% else %}background:repeating-linear-gradient(135deg,#120e09 0,#120e09 11px,#1c1710 11px,#1c1710 22px);{% endif %}"></div>
                <p class="hhs-mat">{{ item.type | default: '18k Gold Vermeil' }}</p>
                <p class="hhs-name">{{ item.title }}</p>
                <span class="hhs-price">{{ item.price | money }}</span>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="hhs-none">
          <p>No results for &ldquo;{{ search.terms }}&rdquo;. Try another search.</p>
          <a class="hhs-btn" href="/collections/all">Browse All Jewelry</a>
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="hhs-none">
        <p>Search our collection of 18k gold vermeil jewelry.</p>
        <a class="hhs-btn" href="/collections/all">Browse All Jewelry</a>
      </div>
    {%- endif -%}
  </div>

  <footer class="hhs-ft">
    <div class="hhs-ft-grid">
      <div>{%- if settings.logo != blank -%}<img class="hhs-ft-logo" src="{{ settings.logo | image_url: height: 104 }}" alt="{{ shop.name }}">{%- else -%}<div class="hhs-ft-logo"><span style="font-family:'Playfair Display',serif;font-size:22px;letter-spacing:0.15em;color:#f2ede1;">HUMBLE HEARTED</span></div>{%- endif -%}<p style="font-size:11px;color:rgba(242,237,225,0.35);line-height:1.8;max-width:230px;font-weight:300;">Luxury for the real. Crafted for people with beautiful hearts.</p></div>
      <div class="col"><h5>Shop</h5><a href="/collections/necklaces">Necklaces</a><a href="/collections/rings">Rings</a><a href="/collections/bracelets">Bracelets</a><a href="/collections/earrings">Earrings</a></div>
      <div class="col"><h5>Help</h5><a href="#">FAQs</a><a href="#">Shipping</a><a href="#">Returns</a></div>
      <div class="col"><h5>About</h5><a href="#">Our Story</a><a href="#">Sustainability</a></div>
    </div>
    <div class="hhs-ft-bot"><p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All Rights Reserved.</p><span>Visa &middot; Mastercard &middot; Amex &middot; Shop Pay &middot; Apple Pay</span></div>
  </footer>
</div>

{% schema %}
{
  "name": "HH Search",
  "settings": [
    { "type": "header", "content": "Announcement Bar" },
    { "type": "text", "id": "announcement_text", "label": "Announcement text", "default": "Free Shipping On Orders $75+ ✦ Sign Up For 10% Off ✦ New: Summer Heart Collection ✦ 60-Day Returns" },
    { "type": "header", "content": "Search Header" },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow", "default": "Search" },
    { "type": "text", "id": "hero_heading", "label": "Heading", "default": "Find Your Piece" }
  ]
}
{% endschema %}
