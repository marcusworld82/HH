{%- assign logo_url = 'hh-logo.png' | asset_url -%}
{%- if settings.logo != blank -%}
  {%- assign logo_src = settings.logo | image_url: height: 124 -%}
{%- else -%}
  {%- assign logo_src = logo_url -%}
{%- endif -%}

{% layout none %}

<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#080808">
  <title>Our Story | {{ shop.name }}</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  {{ content_for_header }}
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    html,body{margin:0;padding:0;background:#080808;overflow-x:hidden;color:#f2ede1;font-family:'Montserrat',sans-serif;}
    a{color:inherit;text-decoration:none;}
    @keyframes marquee{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}
    .hh-nav-inner{max-width:1440px;margin:0 auto;padding:0 48px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;height:80px;}
    .hh-hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:8px;}
    .hh-hamburger span{display:block;width:22px;height:2px;background:#f2ede1;border-radius:1px;}
    .hh-about-hero{height:480px;position:relative;overflow:hidden;background:repeating-linear-gradient(135deg,#120e09 0,#120e09 18px,#1d1710 18px,#1d1710 36px);display:flex;align-items:center;justify-content:center;text-align:center;}
    .hh-about-hero-overlay{position:absolute;inset:0;background:rgba(8,8,8,0.55);}
    .hh-about-hero-inner{position:relative;z-index:2;padding:0 24px;max-width:680px;}
    .hh-eyebrow{font-size:10px;letter-spacing:0.3em;color:#C4A843;font-weight:700;text-transform:uppercase;margin-bottom:18px;}
    .hh-about-h1{font-family:'Playfair Display',serif;font-size:64px;font-weight:400;color:#f2ede1;line-height:1.05;margin-bottom:20px;}
    .hh-about-hero-sub{font-size:14px;color:rgba(242,237,225,0.6);font-weight:300;letter-spacing:0.06em;line-height:1.8;}
    .hh-about-body{max-width:1440px;margin:0 auto;padding:0 48px;}
    .hh-mission{display:grid;grid-template-columns:1fr 1fr;gap:96px;align-items:center;padding:100px 0;}
    .hh-mission-h2{font-family:'Playfair Display',serif;font-size:48px;font-weight:400;color:#f2ede1;line-height:1.15;margin-bottom:28px;}
    .hh-mission-p{font-size:14px;color:rgba(242,237,225,0.6);line-height:2.0;font-weight:300;margin-bottom:20px;}
    .hh-gold-rule{width:48px;height:1px;background:#C4A843;margin-top:8px;}
    .hh-mission-visual{position:relative;aspect-ratio:3/4;background:repeating-linear-gradient(45deg,#100a14 0,#100a14 18px,#180f1e 18px,#180f1e 36px);overflow:hidden;}
    .hh-mission-visual-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(8,8,8,0.7) 0%,transparent 60%);}
    .hh-mission-visual-label{position:absolute;bottom:32px;left:32px;}
    .hh-values{padding:80px 0;border-top:1px solid #1a1510;}
    .hh-values-header{text-align:center;margin-bottom:64px;}
    .hh-values-h2{font-family:'Playfair Display',serif;font-size:42px;font-weight:400;color:#f2ede1;margin-top:12px;}
    .hh-values-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;}
    .hh-value-card{background:#0d0d0d;padding:48px 36px;position:relative;overflow:hidden;}
    .hh-value-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:#C4A843;opacity:0;transition:opacity 0.3s;}
    .hh-value-card:hover::before{opacity:1;}
    .hh-value-icon{font-size:28px;margin-bottom:20px;color:#C4A843;}
    .hh-value-title{font-family:'Playfair Display',serif;font-size:22px;color:#f2ede1;font-weight:400;margin-bottom:14px;}
    .hh-value-text{font-size:13px;color:rgba(242,237,225,0.5);line-height:1.9;font-weight:300;}
    .hh-quote{padding:100px 0;text-align:center;border-top:1px solid #1a1510;}
    .hh-quote-mark{font-family:'Playfair Display',serif;font-size:80px;color:#C4A843;line-height:0.6;margin-bottom:28px;opacity:0.5;}
    .hh-quote-text{font-family:'Playfair Display',serif;font-size:32px;font-weight:400;color:#f2ede1;line-height:1.5;max-width:760px;margin:0 auto 32px;font-style:italic;}
    .hh-quote-attr{font-size:11px;letter-spacing:0.22em;color:#C4A843;text-transform:uppercase;font-weight:700;}
    .hh-promise{border-top:1px solid #1a1510;border-bottom:1px solid #1a1510;}
    .hh-promise-inner{max-width:1440px;margin:0 auto;padding:36px 48px;display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
    .hh-promise-item{display:flex;align-items:flex-start;gap:16px;padding:0 12px;}
    .hh-promise-icon{color:#C4A843;flex-shrink:0;margin-top:2px;}
    .hh-promise-title{font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:#f2ede1;font-weight:700;margin-bottom:4px;}
    .hh-promise-sub{font-size:11px;color:rgba(242,237,225,0.4);font-weight:300;line-height:1.6;}
    .hh-cta-banner{background:repeating-linear-gradient(135deg,#0f0c08 0,#0f0c08 16px,#181410 16px,#181410 32px);padding:96px 48px;text-align:center;}
    .hh-cta-h2{font-family:'Playfair Display',serif;font-size:48px;font-weight:400;color:#f2ede1;margin-bottom:16px;line-height:1.1;}
    .hh-cta-p{font-size:14px;color:rgba(242,237,225,0.55);font-weight:300;margin-bottom:40px;letter-spacing:0.04em;}
    .hh-cta-btn{display:inline-block;padding:18px 60px;background:#C4A843;color:#080808;font-size:11px;letter-spacing:0.22em;font-weight:800;text-transform:uppercase;}
    .hh-ft{background:#080808;padding:48px 48px 28px;border-top:1px solid #1a1510;}
    .hh-ft-inner{max-width:1440px;margin:0 auto;}
    .hh-ft-cols{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:36px;margin-bottom:36px;padding-bottom:36px;border-bottom:1px solid #1a1510;}
    .hh-ft-tag{font-size:11px;color:rgba(242,237,225,0.35);line-height:1.8;max-width:220px;font-weight:300;}
    .hh-ft-h{font-size:10px;letter-spacing:0.16em;color:#f2ede1;text-transform:uppercase;font-weight:700;margin-bottom:14px;}
    .hh-ft-list{display:flex;flex-direction:column;gap:9px;}
    .hh-ft-list a{font-size:12px;color:rgba(242,237,225,0.4);font-weight:300;}
    .hh-ft-bottom{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;}
    .hh-ft-copy{font-size:11px;color:rgba(242,237,225,0.2);font-weight:300;}
    .hh-ft-pay{font-size:10px;color:rgba(242,237,225,0.2);}
    @media(max-width:1024px){.hh-nav-inner{padding:0 28px !important;}.hh-about-body{padding:0 28px;}.hh-mission{gap:48px;padding:72px 0;}.hh-values-grid{grid-template-columns:repeat(2,1fr);}.hh-promise-inner{grid-template-columns:repeat(2,1fr);}.hh-ft-cols{grid-template-columns:repeat(3,1fr);}}
    @media(max-width:768px){.hh-nav-inner{grid-template-columns:auto 1fr auto !important;padding:0 20px !important;height:60px !important;}.hh-nav-left,.hh-nav-right-links,.hh-nav-divider-text{display:none !important;}.hh-hamburger{display:flex !important;}.hh-about-h1{font-size:40px;}.hh-about-body{padding:0 20px;}.hh-mission{grid-template-columns:1fr;gap:36px;padding:56px 0;}.hh-mission-h2{font-size:34px;}.hh-values-grid{grid-template-columns:1fr;}.hh-quote-text{font-size:22px;}.hh-promise-inner{grid-template-columns:1fr 1fr;padding:28px 20px;}.hh-cta-h2{font-size:34px;}.hh-cta-banner{padding:64px 24px;}.hh-ft-cols{grid-template-columns:repeat(2,1fr);}}
  </style>
</head>
<body>

<div id="hhAboutMobileMenu" style="position:fixed;inset:0;z-index:999;background:#080808;display:flex;flex-direction:column;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.35s ease;padding:40px 24px;">
  <button onclick="hhAboutMenu(false)" aria-label="Close" style="position:absolute;top:20px;right:20px;background:none;border:none;cursor:pointer;color:#f2ede1;font-size:32px;line-height:1;padding:8px;">&times;</button>
  <img src="{{ logo_src }}" alt="{{ shop.name }}" style="height:72px;margin-bottom:40px;" onerror="this.style.display='none'">
  <a href="/collections/pendants" style="font-family:'Playfair Display',serif;font-size:28px;color:#f2ede1;text-decoration:none;margin-bottom:18px;">Pendants</a>
  <a href="/collections/rings" style="font-family:'Playfair Display',serif;font-size:28px;color:#f2ede1;text-decoration:none;margin-bottom:18px;">Rings</a>
  <a href="/collections/bracelets" style="font-family:'Playfair Display',serif;font-size:28px;color:#f2ede1;text-decoration:none;margin-bottom:18px;">Bracelets</a>
  <a href="/collections/earrings" style="font-family:'Playfair Display',serif;font-size:28px;color:#f2ede1;text-decoration:none;margin-bottom:18px;">Earrings</a>
  <a href="/collections/necklace" style="font-size:14px;letter-spacing:0.2em;color:#f2ede1;text-decoration:none;margin-bottom:12px;font-weight:700;text-transform:uppercase;">Necklace</a>
  <a href="/collections/all" style="font-size:14px;letter-spacing:0.2em;color:#C4A843;text-decoration:none;margin-bottom:12px;font-weight:700;text-transform:uppercase;">All</a>
  <a href="/pages/about" style="font-size:14px;letter-spacing:0.2em;color:#f2ede1;text-decoration:none;margin-bottom:12px;font-weight:700;text-transform:uppercase;">Our Story</a>
  <div style="width:40px;height:1px;background:#C4A843;margin:20px 0 24px;"></div>
</div>

<div style="background:#C4A843;overflow:hidden;height:38px;display:flex;align-items:center;">
  <div style="display:flex;animation:marquee 36s linear infinite;white-space:nowrap;will-change:transform;">
    <span style="font-size:11px;font-weight:700;letter-spacing:0.2em;color:#080808;padding:0 32px;text-transform:uppercase;">Free Shipping On Orders $75+ &#10022; Sign Up For 10% Off &#10022; New: Summer Heart Collection &#10022; 60-Day Returns &nbsp;&#10022;&nbsp; Free Shipping On Orders $75+ &#10022; Sign Up For 10% Off &#10022; New: Summer Heart Collection &#10022; 60-Day Returns &nbsp;&#10022;&nbsp;</span>
  </div>
</div>

<nav style="background:#080808;border-bottom:1px solid #1a1510;position:sticky;top:0;z-index:200;">
  <div class="hh-nav-inner">
    <button class="hh-hamburger" onclick="hhAboutMenu(true)" aria-label="Open menu"><span></span><span></span><span></span></button>
    <div style="display:flex;gap:32px;align-items:center;" class="hh-nav-left">
      <a href="/collections/pendants" style="color:#f2ede1;font-size:11px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;">Pendants</a>
      <a href="/collections/rings" style="color:#f2ede1;font-size:11px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;">Rings</a>
      <a href="/collections/bracelets" style="color:#f2ede1;font-size:11px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;">Bracelets</a>
      <a href="/collections/earrings" style="color:#f2ede1;font-size:11px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;">Earrings</a>
    </div>
    <a href="/" style="display:block;line-height:0;justify-self:center;"><img src="{{ logo_src }}" alt="{{ shop.name }}" style="height:62px;width:auto;display:block;" onerror="this.outerHTML='<span style=&quot;font-family:Playfair Display,serif;font-size:26px;letter-spacing:0.15em;color:#f2ede1;&quot;>HUMBLE HEARTED</span>'"></a>
    <div style="display:flex;gap:28px;align-items:center;justify-content:flex-end;">
      <div style="display:flex;gap:28px;align-items:center;" class="hh-nav-right-links">
        <a href="/collections/necklace" style="color:#f2ede1;font-size:11px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;">Necklace</a>
        <a href="/collections/all" style="color:#f2ede1;font-size:11px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;">All</a>
        <a href="/collections" style="color:#f2ede1;font-size:11px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;">Collections</a>
        <a href="/pages/about" style="color:#C4A843;font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;">Our Story</a>
      </div>
      <div style="display:flex;gap:18px;align-items:center;border-left:1px solid #1f1a14;padding-left:24px;margin-left:4px;" class="hh-nav-divider-text">
        <a href="/search" style="color:#f2ede1;line-height:0;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path></svg></a>
        <a href="/account" style="color:#f2ede1;line-height:0;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></a>
        <a href="/cart" style="color:#f2ede1;line-height:0;position:relative;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f2ede1" stroke-width="1.5" stroke-linecap="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg><span style="position:absolute;top:-7px;right:-7px;background:#8B1818;color:white;font-size:9px;width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;">{{ cart.item_count }}</span></a>
      </div>
    </div>
  </div>
</nav>

<section class="hh-about-hero">
  <div class="hh-about-hero-overlay"></div>
  <div class="hh-about-hero-inner">
    <p class="hh-eyebrow">Humble Hearted Jewelry Co.</p>
    <h1 class="hh-about-h1">Luxury for<br><em>the Real.</em></h1>
    <p class="hh-about-hero-sub">Meaning-first jewelry for people who know their worth.</p>
  </div>
</section>

<div class="hh-about-body">
  <div class="hh-mission">
    <div class="hh-mission-text">
      <p class="hh-eyebrow">Our Story</p>
      <h2 class="hh-mission-h2">We believe beautiful things should feel like you.</h2>
      <p class="hh-mission-p">Humble Hearted was built on a single belief: luxury jewelry should not require you to pretend. Not pretend to be richer, cooler, or more put-together than you are. Just real. Just you.</p>
      <p class="hh-mission-p">We create pieces that feel personal because they are. Every design starts with a question: what would make someone feel genuinely seen? Not flashy. Not performative. Just quietly, confidently themselves.</p>
      <p class="hh-mission-p">We craft everything from 18k gold vermeil over sterling silver. Nickel-free. Hypoallergenic. Made to be worn every day, layered, gifted, and kept.</p>
      <div class="hh-gold-rule"></div>
    </div>
    <div class="hh-mission-visual">
      <div class="hh-mission-visual-overlay"></div>
      <div class="hh-mission-visual-label">
        <p style="font-size:9px;letter-spacing:0.22em;color:#C4A843;text-transform:uppercase;font-weight:700;margin-bottom:8px;">Crafted With Intention</p>
        <p style="font-family:'Playfair Display',serif;font-size:26px;color:#f2ede1;font-weight:400;line-height:1.2;">18k Gold Vermeil<br>Sterling Silver</p>
      </div>
    </div>
  </div>

  <div class="hh-values">
    <div class="hh-values-header">
      <p class="hh-eyebrow">What We Stand For</p>
      <h2 class="hh-values-h2">The Humble Hearted Way</h2>
    </div>
    <div class="hh-values-grid">
      <div class="hh-value-card"><div class="hh-value-icon">&#9825;</div><h3 class="hh-value-title">Meaning First</h3><p class="hh-value-text">Every piece is designed to mean something. We do not lead with hype or status. We lead with story, feeling, and the kind of beauty that lasts longer than a trend.</p></div>
      <div class="hh-value-card"><div class="hh-value-icon">&#10022;</div><h3 class="hh-value-title">Accessible Luxury</h3><p class="hh-value-text">Fine jewelry should not be a privilege. Our 18k gold vermeil craftsmanship delivers a luxury experience at a price that respects your real life and your real budget.</p></div>
      <div class="hh-value-card"><div class="hh-value-icon">&#9670;</div><h3 class="hh-value-title">Genuine Quality</h3><p class="hh-value-text">Nickel-free, hypoallergenic, and built to last. We stand behind every piece with a 60-day return policy and a commitment to materials that are honest about what they are.</p></div>
      <div class="hh-value-card"><div class="hh-value-icon">&#9776;</div><h3 class="hh-value-title">Self-Expression</h3><p class="hh-value-text">Layer it. Stack it. Wear it alone at 7am or dressed up at midnight. Our pieces are designed to work with your life, your style, and your mood, not against it.</p></div>
      <div class="hh-value-card"><div class="hh-value-icon">&#9825;</div><h3 class="hh-value-title">Community</h3><p class="hh-value-text">We are building more than a brand. We are building a space for women who know who they are, appreciate the beauty in ordinary moments, and want jewelry that reflects that.</p></div>
      <div class="hh-value-card"><div class="hh-value-icon">&#10022;</div><h3 class="hh-value-title">Real Gifting</h3><p class="hh-value-text">Some of our most meaningful moments are gifted. Every order ships in signature packaging, ready to give. Because the right piece at the right moment changes everything.</p></div>
    </div>
  </div>

  <div class="hh-quote">
    <div class="hh-quote-mark">&ldquo;</div>
    <p class="hh-quote-text">We are not for everyone. We are for the woman who knows her worth, loves beautiful things, and does not need a label to prove it.</p>
    <p class="hh-quote-attr">Humble Hearted Jewelry Co.</p>
  </div>
</div>

<div class="hh-promise">
  <div class="hh-promise-inner">
    <div class="hh-promise-item"><svg class="hh-promise-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg><div><p class="hh-promise-title">Free Shipping</p><p class="hh-promise-sub">On all orders $75+</p></div></div>
    <div class="hh-promise-item"><svg class="hh-promise-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><div><p class="hh-promise-title">18k Gold Vermeil</p><p class="hh-promise-sub">Nickel-free &amp; hypoallergenic</p></div></div>
    <div class="hh-promise-item"><svg class="hh-promise-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg><div><p class="hh-promise-title">60-Day Returns</p><p class="hh-promise-sub">Hassle-free, no questions</p></div></div>
    <div class="hh-promise-item"><svg class="hh-promise-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg><div><p class="hh-promise-title">Signature Packaging</p><p class="hh-promise-sub">Every order arrives gift-ready</p></div></div>
  </div>
</div>

<div class="hh-cta-banner">
  <p class="hh-eyebrow" style="margin-bottom:16px;">Ready to Shop</p>
  <h2 class="hh-cta-h2">Find Your Piece.</h2>
  <p class="hh-cta-p">Crafted for real moments. Built for real people.</p>
  <a href="/collections/all" class="hh-cta-btn">Shop the Collection</a>
</div>

<footer class="hh-ft">
  <div class="hh-ft-inner">
    <div class="hh-ft-cols">
      <div>{%- if settings.logo != blank -%}<img src="{{ settings.logo | image_url: height: 104 }}" alt="{{ shop.name }}" style="height:52px;width:auto;display:block;margin-bottom:12px;">{%- else -%}<span style="font-family:'Playfair Display',serif;font-size:22px;color:#f2ede1;letter-spacing:0.15em;display:block;margin-bottom:12px;">HUMBLE HEARTED</span>{%- endif -%}<p class="hh-ft-tag">Luxury for the real. Crafted for people with beautiful hearts.</p></div>
      <div><h5 class="hh-ft-h">Shop</h5><div class="hh-ft-list"><a href="/collections/pendants">Pendants</a><a href="/collections/rings">Rings</a><a href="/collections/bracelets">Bracelets</a><a href="/collections/earrings">Earrings</a><a href="/collections/necklace">Necklace</a></div></div>
      <div><h5 class="hh-ft-h">Help</h5><div class="hh-ft-list"><a href="/pages/faq">FAQ</a><a href="/pages/shipping">Shipping</a><a href="/pages/returns">Returns</a><a href="/pages/contact">Contact Us</a></div></div>
      <div><h5 class="hh-ft-h">Company</h5><div class="hh-ft-list"><a href="/pages/about">Our Story</a><a href="/collections">All Collections</a><a href="/collections/all">All Products</a></div></div>
    </div>
    <div class="hh-ft-bottom"><p class="hh-ft-copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All Rights Reserved.</p><span class="hh-ft-pay">Visa &middot; Mastercard &middot; Shop Pay &middot; Apple Pay</span></div>
  </div>
</footer>

<script>function hhAboutMenu(open){var m=document.getElementById('hhAboutMobileMenu');m.style.opacity=open?'1':'0';m.style.pointerEvents=open?'auto':'none';}</script>
</body>
</html>
